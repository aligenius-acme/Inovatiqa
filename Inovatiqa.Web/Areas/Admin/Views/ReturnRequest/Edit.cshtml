@model ReturnRequestModel

@{
    //page title
    ViewBag.PageTitle = "Edit return request details";
}

<form asp-controller="ReturnRequest" asp-action="Edit" method="post">
    <div class="content-header clearfix">
        <h1 class="pull-left">
            Edit return request details
            <small>
                <i class="fa fa-arrow-circle-left"></i>
                <a asp-action="List">back to return request list</a>
            </small>
        </h1>
        <div class="pull-right">
            <button type="submit" name="notify-customer" class="btn bg-aqua">
                <i class="fa fa-envelope-o"></i>
                Notify customer about status change
            </button>
            <button type="submit" name="save" class="btn bg-blue">
                <i class="fa fa-floppy-o"></i>
                Save
            </button>
            <button type="submit" name="save-continue" class="btn bg-blue">
                <i class="fa fa-floppy-o"></i>
                Save and Continue Edit
            </button>
            <span id="returnrequest-delete" class="btn bg-red">
                <i class="fa fa-trash-o"></i>
                Delete
            </span>
        </div>
    </div>
    @await Html.PartialAsync("_CreateOrUpdate", Model)
</form>
<nop-delete-confirmation asp-model-id="@Model.Id" asp-button-id="returnrequest-delete" />