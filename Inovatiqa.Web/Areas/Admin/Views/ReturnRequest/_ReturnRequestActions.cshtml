@model ReturnRequestActionSearchModel

<div class="panel panel-default">
    <div class="panel-heading">
        Return request actions
    </div>
    <div class="panel-body">
        @await Html.PartialAsync("Table",  new DataTablesModel
        {
            Name = "returnrequestactions-grid",
            UrlRead = new DataUrl("ReturnRequestActionList", "ReturnRequest", null),
            Length = Model.PageSize,
            LengthMenu = Model.AvailablePageSizes,
            ColumnCollection = new List<ColumnProperty>
            {
                new ColumnProperty(nameof(ReturnRequestActionModel.Name))
                {
                    Title = "Name",
                    Width = "300"
                },
                new ColumnProperty(nameof(ReturnRequestActionModel.DisplayOrder))
                {
                    Title = ">Display order",
                    Width = "100",
                    ClassName =  InovatiqaColumnClassDefaults.CenterAll
                },
                new ColumnProperty(nameof(ReturnRequestActionModel.Id))
                {
                    Title = "Edit",
                    Width = "100",
                    ClassName =  InovatiqaColumnClassDefaults.Button,
                    Render = new RenderButtonEdit(new DataUrl("~/Admin/ReturnRequest/ReturnRequestActionEdit/"))
                }
            }
        })
    </div>
    <div class="panel-footer">
        <a asp-action="ReturnRequestActionCreate" asp-controller="ReturnRequest" class="btn btn-primary">
            <i class="fa fa-plus-square"></i>
            Add new
        </a>
    </div>
</div>