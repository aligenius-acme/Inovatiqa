@model CustomerAddressModel

@{
    //page title
    ViewBag.PageTitle = "Edit address";
}

<form asp-controller="Customer" asp-action="AddressEdit" method="post">
    <div class="content-header clearfix">
        <h1 class="pull-left">
            Edit address
            <small>
                <i class="fa fa-arrow-circle-left"></i>
                <a asp-action="Edit" asp-route-id="@Model.CustomerId">back to customer details</a>
            </small>
        </h1>
        <div class="pull-right">
            <button type="submit" name="save" class="btn bg-blue">
                <i class="fa fa-floppy-o"></i>
                Save
            </button>
        </div>
    </div>
    @await Html.PartialAsync("_CreateOrUpdateAddress", Model)
</form>