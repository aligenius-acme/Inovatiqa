    <div class="form-group">
        <div class="col-md-3">
            <nop-label asp-for="SelectedCategoryIds" />
        </div>
        <div class="col-md-9">
            @*<nop-select asp-for="SelectedCategoryIds" asp-items="Model.AvailableCategories" asp-multiple="true" />*@
            <select asp-for="SelectedCategoryIds" multiple="multiple"></select>
            @Html.Resource(@<script type="text/javascript">
                $(document).ready(function () {
                    $("#SelectedCategoryIds").kendoMultiSelect({
                        dataTextField: "Text",
                        dataValueField: "Value"
                    });


                    if (localStorage["adminCategories"] != undefined && localStorage["adminCategories"] != null) {
                        var availableCategories = localStorage["adminCategories"].replace('[', '').replace(']', '');
                        availableCategories = $.parseJSON('[' + availableCategories + ']');
                        var selectedCatIds = @(Html.Raw(Newtonsoft.Json.JsonConvert.SerializeObject(Model.SelectedCategoryIds)));
                        var dataSource = new kendo.data.DataSource({
                            data: availableCategories              
                        });
  
                        var multiselect = $("#SelectedCategoryIds").data("kendoMultiSelect");
                        multiselect.setDataSource(dataSource);
                        multiselect.value(selectedCatIds)
                    }
                    else {
                        $.ajax({
                            cache: false,
                            type: "GET",
                            url: "@(Url.Action("PopulateCategoryList", "Category"))",
                            success: function (data, textStatus, jqXHR) {
                                if (data != null) {
                                    localStorage.setItem('adminCategories', JSON.stringify(data.AvailableCategories));
                                    var availableCategories = localStorage["adminCategories"].replace('[','').replace(']','');
                                    var dataSource = new kendo.data.DataSource({
                                        data: $.parseJSON('[' + availableCategories + ']'),
                                        pageSize: 10              
                                    });
  
                                    var categoryIdsInput = $("#SelectedCategoryIds").data("kendoMultiSelect");
                                    categoryIdsInput.setDataSource(dataSource);
                                    categoryIdsInput.setOptions({
                                        autoClose: false,
                                        filter: "contains"
                                    });
                                }
                            },
                            error: function (jqXHR, textStatus, errorThrown) { }
                        });
                    }
                });
            </script>, "js")
        </div>
    </div>
