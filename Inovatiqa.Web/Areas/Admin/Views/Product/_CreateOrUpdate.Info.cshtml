@{
    @Html.Resource(@<link href="@Url.Content("~/lib/tagEditor/jquery.tag-editor.css")" rel="stylesheet" type="text/css" />, "css")
    @Html.Resource(@<script src="@Url.Content("~/lib/tagEditor/jquery.tag-editor.min.js")" type="text/javascript"></script>, "js")
    @Html.Resource(@<script src="@Url.Content("~/lib/tagEditor/jquery.caret.min.js")" type="text/javascript"></script>, "js")
