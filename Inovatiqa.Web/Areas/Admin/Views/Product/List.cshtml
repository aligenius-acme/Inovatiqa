@model ProductSearchModel
@inject Inovatiqa.Services.WorkContext.Interfaces.IWorkContextService workContextService
@{
    ViewBag.PageTitle = "Products";
}

@{
    const string hideSearchBlockAttributeName = "ProductListPage.HideSearchBlock";
    var hideSearchBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideSearchBlockAttributeName, workContextService.CurrentCustomer.Id);
}

