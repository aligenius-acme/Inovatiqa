@model ManufacturerModel

@inject Inovatiqa.Services.Common.Interfaces.IGenericAttributeService genericAttributeService
@inject IWorkContextService workContextService

@{
	const string hideInfoBlockAttributeName = "ManufacturerPage.HideInfoBlock";
	var hideInfoBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideInfoBlockAttributeName, workContextService.CurrentCustomer.Id);

	const string hideDisplayBlockAttributeName = "ManufacturerPage.HideDisplayBlock";
	var hideDisplayBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideDisplayBlockAttributeName, workContextService.CurrentCustomer.Id, defaultValue: true);

	const string hideMappingsBlockAttributeName = "ManufacturerPage.HideMappingsBlock";
	var hideMappingsBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideMappingsBlockAttributeName, workContextService.CurrentCustomer.Id, defaultValue: true);

	const string hideSeoBlockAttributeName = "ManufacturerPage.HideSEOBlock";
	var hideSeoBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideSeoBlockAttributeName, workContextService.CurrentCustomer.Id, defaultValue: true);

	const string hideProductsBlockAttributeName = "ManufacturerPage.HideProductsBlock";
	var hideProductsBlock = genericAttributeService.GetAttribute<bool>(workContextService.CurrentCustomer, hideProductsBlockAttributeName, workContextService.CurrentCustomer.Id, defaultValue: true);
}

<div asp-validation-summary="All"></div>
<input asp-for="Id" type="hidden" />

<div class="content">
    <div class="form-horizontal">
        @*<div class="row">
            <div class="col-md-12 clearfix">
                <div class="pull-left">
                    @await Component.InvokeAsync("SettingMode", new { modeName = "manufacturer-advanced-mode" })
                </div>
            </div>
        </div>*@

        <nop-panels id="manufacturer-panels">
            <nop-panel asp-name="manufacturer-info" asp-icon="fa fa-info" asp-title="Manufacturer info" asp-hide-block-attribute-name="@hideInfoBlockAttributeName" asp-hide="@hideInfoBlock" asp-advanced="false">@await Html.PartialAsync("_CreateOrUpdate.Info", Model)</nop-panel>
            <nop-panel asp-name="manufacturer-display" asp-icon="fa fa-television" asp-title="Display" asp-hide-block-attribute-name="@hideDisplayBlockAttributeName" asp-hide="@hideDisplayBlock" asp-advanced="false">@await Html.PartialAsync("_CreateOrUpdate.Display", Model)</nop-panel>
            @*<nop-panel asp-name="manufacturer-mappings" asp-icon="fa fa-bookmark" asp-title="Mappings" asp-hide-block-attribute-name="@hideMappingsBlockAttributeName" asp-hide="@hideMappingsBlock" asp-advanced="true">@await Html.PartialAsync("_CreateOrUpdate.Mappings", Model)</nop-panel>*@
            @*<nop-panel asp-name="manufacturer-seo" asp-icon="fa fa-search-plus" asp-title="SEO" asp-hide-block-attribute-name="@hideSeoBlockAttributeName" asp-hide="@hideSeoBlock" asp-advanced="true">@await Html.PartialAsync("_CreateOrUpdate.Seo", Model)</nop-panel>*@
            <nop-panel asp-name="manufacturer-products" asp-icon="fa fa-th-list" asp-title="Products" asp-hide-block-attribute-name="@hideProductsBlockAttributeName" asp-hide="@hideProductsBlock" asp-advanced="true">@await Html.PartialAsync("_CreateOrUpdate.Products", Model)</nop-panel>
        </nop-panels>
    </div>
</div>