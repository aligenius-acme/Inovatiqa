                                    window.location.href = "/wishlistbyname/" + $(this).val();
                                else
                                    window.location.href = "/wishlist";
                            });

                            $("#removeWishList").click(function () {
                                var wishListId = $("#wishListDDLWishlist").val();

                                if (wishListId === "0") {
                                    alert("Please select wishlist first.");
                                    return;
                                }

                                if (confirm("Are you sure you wanted to remove this wishlist and all of its items?")) {
                                    setLoadWaiting(true);
                                    $.ajax({
                                        cache: false,
                                        data: { "wishListId": wishListId },
                                        type: "GET",
                                        url: "/ShoppingCart/RemoveWishList",
                                        success: function (data, textStatus, jqXHR) {
                                            setLoadWaiting(false);
                                            alert("Wishlist and all of its items have been removed successfully!");
                                            window.location.href = "/wishlist";
                                        },
                                        error: function (jqXHR, textStatus, errorThrown) {
                                            setLoadWaiting(false);
                                        }
                                    });
                                }
                            });
                            $('#tblwishlist').DataTable({
                                "dom": '<"pull-left"f> <"pull-left"l>t<"pull-left"i><"pull-right"p>',
