<script>
    $(document).ready(function () {
        const dt = $('#tblwishlist').DataTable({
            "language": {
                "info": '<div class="tpage-num"><p>Displaying Lines _START_ to _END_ of _TOTAL_</p></div>'
            },
            "pagingType": "numbers",
            "dom": 't<"jqueryPagination"ip>',
            "pageLength": 5
        });
        $("#wishListClear").click(function () {
            if (isReturnview)
                setLocation('@Url.RouteUrl("Wishlist")?returnView=true');
            else {
                setLocation('@Url.RouteUrl("Wishlist")');
            }
        });

        $('#tblwishlist_length').hide();
        $('#tblwishlist_filter').hide();
        $('#tableFilter').keyup(function () {
            dt.search($(this).val()).draw();
        });
    });
function wishListFind() {
    var category = $('#CategoryFilter').val();
    //setLocation('@Url.RouteUrl("Wishlist")?CategoryFilter=' + category);
    window.location.href = '/wishlist?CategoryFilter=' + category;
}
</script>