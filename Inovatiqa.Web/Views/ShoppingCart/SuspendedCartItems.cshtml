@model ShoppingCartModel
@{
    Layout = "_ColumnsOne";
}
@{
    ViewBag.Title = "Shopping Cart";
}
@*@Html.Resource(@<link href="@Url.Content("https://cdn.datatables.net/1.10.22/css/dataTables.bootstrap4.min.css")" rel="stylesheet" type="text/css" />, "css")
@Html.Resource(@<script src="@Url.Content("https://cdn.datatables.net/1.10.22/js/jquery.dataTables.min.js")" type="text/javascript"></script>, "js")
@Html.Resource(@<script src="@Url.Content("https://cdn.datatables.net/1.10.22/js/dataTables.bootstrap4.min.js")" type="text/javascript"></script>, "js")
*@@*
    <div class="page shopping-cart-page from-panel">
        <div class="page-title panel-heading">
            <h1>Suspended Cart</h1>
        </div>



        <div class="col-lg-12">
            <div class="tab-content">
                <div class="full-description fade tab-pane in active" id="description" style="font-family:Helvetica Neue,Helvetica,Arial,sans-serif;">
                            <div>
                                <div style="float: right;width: 20%;">
                                    <div class="buttons">
                                    </div>
                                </div>
                            </div>
                            <div>
                                <table class="cart table table-bordered table-wrapper dataTable no-footer" id="shopping-cart-table">
                                    <thead>
                                        <tr class="cart-header-row">
                                            <th class="remove-from-cart" style="display:none;">
                                            </th>
                                            <th class="remove-from-cart">
                                                Item #
                                            </th>
                                            <th class="product">
                                                Name
                                            </th>
                                            <th class="sku">
                                                Mfr #
                                            </th>
                                            <th class="vendor">
                                                UOM
                                            </th>
                                            <th class="unit-price">
                                                Price
                                            </th>
                                            <th class="quantity">
                                                Qty
                                            </th>
                                            <th class="end subtotal">
                                                Total
                                            </th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if(Model.Items.Count > 0)
                                        {
                                            foreach(var item in Model.Items)
                                            {
                                                <tr>
                                                    <td>@item.Sku</td>
                                                    <td>@item.ProductName</td>
                                                    <td>@item.ManufacturerPartNumber</td>
                                                    <td>@item.UOM</td>
                                                    <td>@item.UnitPrice</td>
                                                    <td>@item.Quantity</td>
                                                    <td>@item.SubTotal</td>
                                                </tr>
                                            }
                                        }
                                        else
                                        {
                                            <tr>
                                                <td colspan="10">
                                                    <div class="no-data">
                                                        There are no items in your cart
                                                    </div>
                                                </td>
                                            </tr>
                                        }

                                    </tbody>
                                </table>
                            </div>
                </div>
            </div>

    </div>

*@


<style>
    .jqueryPagination{
        display: @(Model.Items.Count > 0 ? "flex" : "none");
        justify-content: space-between;
    }
    .paging_numbers span a {
        margin-right: 5px;
        cursor: pointer;
        color: #636363;
    }
    .paging_numbers span .current{
        color: #000;
    }
    .paging_numbers{
        padding-top:10px;
    }
    .jqueryPagination p {
        font-family: Lato;
        font-style: normal;
        font-weight: normal;
        font-size: 13.5px;
        letter-spacing: 0.05em;
        color: #636363;
        margin-bottom:unset;
    }

</style>


@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@
<section class="container-fluid orderstatus-area">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="dashboard-area">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="sidebar_menu font_lato">
                                    <h3>Inovatiqa Dashboard</h3>
                                    @await Html.PartialAsync("_DashboardSideBar", "inovatiqa-orders")
                                </div>
                            </div>
                            <div class="col-md-9">
                                <div class="order-deatil-area sorder-staus sinvoice-order">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="tabs font_lato">
                                                @await Html.PartialAsync("_OrderNewTopBar", "suspended-carts")
                                                <hr>
                                            </div>
                                        </div>
                                        <div class="col-md-12">
                                            <div class="order-content">
                                                <div class="tab-content" style="border: none !important;">
                                                    <div class="contact-manager text-right font_roboto">
                                                        <a href="#" class="btn conatct-btnpopup" data-toggle="modal" data-target="#contact-mform">Contact Your Account Manager</a>
                                                    </div>


                                                    <div class="saddress-area font_lato">
                                                        <div class="row">
                                                            <div class="col-md-4 col-sm-4">
                                                                <div class="acc-info">
                                                                    <h5>Account</h5>
                                                                    <p>#@Model.OrderReviewData.BillingAddress.Id @Model.OrderReviewData.BillingAddress.Company</p>
                                                                    <p>@Model.OrderReviewData.BillingAddress.Address1
                                                                    <br> @Model.OrderReviewData.BillingAddress.City, @Model.OrderReviewData.BillingAddress.StateProvinceName, 
                                                                    @Model.OrderReviewData.BillingAddress.ZipPostalCode</p>
                                                                </div>
                                                            </div>
                                                            <div class="col-md-4 col-sm-4">
                                                                <div class="acc-info adds-info">
                                                                    <h5>Ship To</h5>
                                                                    <p>#@Model.OrderReviewData.ShippingAddress.Id @Model.OrderReviewData.ShippingAddress.Company</p>
                                                                    <p>@Model.OrderReviewData.ShippingAddress.Address1
                                                                    <br> @Model.OrderReviewData.ShippingAddress.City, @Model.OrderReviewData.ShippingAddress.StateProvinceName, 
                                                                    @Model.OrderReviewData.ShippingAddress.ZipPostalCode</p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="saddress-area font_lato" style="background-color: #F0FFDD;">
                                                        <div class="row">
                                                            <div class="col-md-12 col-sm-12">
                                                                <div class="acc-info">
                                                                    <p>
                                                                        Alert: Items that are on allocation require you to have prior purchase history or the item will be canceled from your order.
                                                                        Quantity not at your warehouse will be backordered up to your allocated amount.
                                                                        For additional assistance, <a href="#" style="color: #FF8B00;" data-toggle="modal" data-target="#contact-mform">click here</a> to contact your Account Manager.
                                                                    </p>
                                                                </div>
                                                            </div>
                                                        </div>
                                                    </div>


                                                    <div class="items-table-area sorder-infotable sinvoicet table-responsive font_roboto">
                                                        <table class="table border-collapse mb0" id="suspendedCard">
                                                            <thead>
                                                                <tr>
                                                                    <th>Item Number</th>
                                                                    <th>Description</th>
                                                                    <th>Manufacturer / #</th>
                                                                    <th>UOM</th>
                                                                    <th>Price</th>
                                                                    <th>Quantity</th>
                                                                    <th>Total</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @if (Model.Items.Count > 0)
                                                                {
                                                                    foreach (var item in Model.Items)
                                                                    {
                                                                        <tr>

                                                                            <td>
                                                                                <p>@item.Sku</p>
                                                                            </td>
                                                                            <td style="width: 30%;">
                                                                                <a href="@Url.RouteUrl("Manufacturer", new { SeName = item.ProductSeName})"><p class="invoicet-blue">@item.ProductName</p></a>
                                                                                <p style="color: #6A983C;">In stock, ships from your local warehouse</p>
                                                                            </td>
                                                                            <td>
                                                                                <p>@(item.ProductManufacturers.Count > 0 ? item.ProductManufacturers.FirstOrDefault().Name : "N/A") /</p>
                                                                                <p>@item.ManufacturerPartNumber</p>
                                                                            </td>
                                                                            <td>
                                                                                <p>@item.UOM</p>
                                                                            </td>
                                                                            <td>
                                                                                <p>@item.UnitPrice</p>
                                                                            </td>
                                                                            <td>
                                                                                <p>@item.Quantity</p>
                                                                            </td>
                                                                            <td>
                                                                                <p>@item.SubTotal</p>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                                else
                                                                {
                                                                    <tr>

                                                                        <td colspan="3">
                                                                            <p>No items in this cart.</p>
                                                                        </td>
                                                                    </tr>
                                                                }
                                                            </tbody>
                                                        </table>
                                                    
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@await Html.PartialAsync("_ContactAccountManagerModal")


<script>
    $(document).ready(function () {
        const dt = $('#suspendedCard').DataTable({
            "language": {
                "info": '<div class="tpage-num"><p>Showing _START_ to _END_ of _TOTAL_ Items</p></div>'
            },
            "pageLength": 5,
            "dom": 't<"jqueryPagination"ip>',
            'pagingType': 'numbers'
        });
    });
</script>