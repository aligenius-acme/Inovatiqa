<script>
    $(document).ready(function () {
        const table = $('#suspended-cart').DataTable({
            "language": {
                "info": '<div class="tpage-num"><p>Showing _START_ to _END_ of _TOTAL_ Items</p></div>'
            },
            "pageLength": 5,
            "dom": 't<"jqueryPagination"ip>',
            'pagingType': 'numbers',
            'ordering':false
        });
        function filterByColumn() {
            table
                .search(this.value)
                .draw();
            @*var columnNumber = Number($('#columnSelector').val());
            if (columnNumber != -1) {
                table
                    .column(columnNumber)
                    .search(this.value)
                    .draw();
            }
            else {
                table
                    .search(this.value)
                    .draw();
            }*@
        }
        $('#Find').keyup(filterByColumn);
    });
    $(document).ready(function () {

        /*const DT = $('#suspended-cart').DataTable({
            dom: 'lrtp',
            "paging": false,
            "ordering": false,
        });
        */
        $('#Find').keyup(function () {
            DT.search($(this).val()).draw();
        });

        $('.check_all').click(function (event) {
            if (this.checked) {
                // Iterate each checkbox
                $(':checkbox').each(function () {
                    this.checked = true;
                });
            } else {
                $(':checkbox').each(function () {
                    this.checked = false;
                });
            }
        });
        $('#clear').click(function () {
            $('#Find').val('');
            $('#Find').keyup();
        });
    });
</script>