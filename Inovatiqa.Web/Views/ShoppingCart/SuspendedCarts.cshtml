    <div class="page account-page suspended-cart-page from-panel">
        <div class="page-title panel-heading">
            <h1>Suspended Carts</h1>
        </div>
        <div class="page-body">
            <h6 style="margin-left: 15px">To Resume a Suspended Cart click on a cart from the list below. Carts will be deleted after 60 days of inactivity.</h6>
            <br />
            <div class="cart-list">
                <div style="float:right;">
                    <input type="button" id="addToCartList" name="addToCartList" value="MERGE TO CURRENT CART" style="margin-bottom:20px" class="btn btn_blue suspended-add-to-cart">
                    <input type="button" id="delete" name="delete" value="DELETE" style="margin-bottom:20px" class="btn btn_blue delete-suspended-cart-button">
                </div>
                <br />
                <br />
                <br />
                <table id="suspended-cart" class="table table-bordered table-condensed table-striped" style="width:100%">
                    <thead>
                        <tr>
                            <th style="text-align:center;white-space:nowrap">
                                Cart #
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                PO/Cart Name
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                Ship To
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                Ship To Name
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                Cart Owner
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                Total Lines
                            </th>
                            <th style="text-align:center;white-space:nowrap">
                                Last Modified Date
                            </th>
                            <th style="text-align:center;white-space:nowrap">

                            </th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (Model.Count > 0)
                        {
                            @foreach (var suspendedCartModel in Model)
                            {
                                <tr id="@suspendedCartModel.Id">
                                    <td>
                                        <a href="@Url.Action("SuspendedCartItems", new {SuspendedCartId = suspendedCartModel.Id })" id="@suspendedCartModel.Id">@suspendedCartModel.Id.ToString().PadLeft(9, '0')</a>
                                    </td>
                                    <td>
                                        @suspendedCartModel.POName
                                    </td>
                                    <td>
                                        @suspendedCartModel.ShipToAddressId
                                    </td>
                                    <td>
                                        @suspendedCartModel.ShipToCompanyName
                                    </td>
                                    <td style="font-weight:bold;color:#393">
                                        @(String.Format("{0} {1}", suspendedCartModel.ShipToFirstName, suspendedCartModel.ShipToLastName))
                                    </td>
                                    <td>
                                        @suspendedCartModel.TotalLines
                                    </td>
                                    <td>
                                        @if (suspendedCartModel.LastModifiedDate != null)
                                            @DateTime.Parse(@suspendedCartModel.LastModifiedDate.ToString()).ToString("MM/dd/yyyy")
                                    </td>
                                    <td>
                                        <input type="checkbox" class="btn btn-default" id="@suspendedCartModel.Id" />
                                    </td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="8">
                                    <div class="no-data">
                                        No suspended carts
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>

            </div>
        </div>
    </div>
