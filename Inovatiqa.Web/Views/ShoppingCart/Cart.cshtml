@model ShoppingCartModel
@{
    Layout = "_ColumnsOne";
}
@{
    ViewBag.Title = "Shopping Cart";
}
<style>
    .jqueryPagination{
        margin: 0 !important;
    }
    .paging_numbers{
        padding-top:8px;
    }
</style>
