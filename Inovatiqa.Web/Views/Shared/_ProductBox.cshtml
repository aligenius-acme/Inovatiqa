@{ 
    // Get UOM, Price, MFR

    var UOM = Model.ProductAttributes.Where(attribute => attribute.Name == "UOM").FirstOrDefault();

    var uomMOdel = UOM != null ? UOM.Values.Where(uom => uom.PriceAdjustment == null && uom.PriceAdjustmentValue == 0).FirstOrDefault() : null;

    var Color = Model.ProductAttributes.Where(attribute => attribute.Name == "Color Options").FirstOrDefault();
    var colorOptions = Color != null ? Color.Values.Where(co => co.PriceAdjustment == null && co.PriceAdjustmentValue == 0).FirstOrDefault() : null;

    }
<div class="product_box" data-productid="@Model.Id">
    <div class="prod_img">
        <div class="top_icon">
            <a href="#" style="width: 100%;" class="like_icon" id="add-to-wishlist-button-@Model.Id"  data-productid="@Model.Id" onclick="AjaxCart.addproducttocart_details('@Url.RouteUrl("AddProductToCart-Details", new { productId = Model.Id, shoppingCartTypeId = (int)ShoppingCartType.Wishlist, WishListId = 0})', '#product-details-form_@Model.Id', @((int)ShoppingCartType.Wishlist)); return false;"><img src="\images\UIComponents\heart.svg" /></a>
           @* <a href="#" onclick="AjaxCart.addproducttocart_catalog('@addtowishlistlink', @((int)ShoppingCartType.Wishlist));return false;" class="like_icon"><img src="\images\UIComponents\heart.svg" /></a>
           *@ <a href="#" onclick="AjaxCart.addproducttocart_productlisting('@Url.RouteUrl("AddProductToCart-ProductListing", new { productId = Model.Id, quantity = 1 })', @Model.Id); return false;" class="cart_icon"><img src="\images\UIComponents\ic3.svg" /></a>
        </div>
        <a href="@Url.RouteUrl("Product", new {SeName = Model.SeName})"><img alt="@Model.DefaultPictureModel.AlternateText" src="@Model.DefaultPictureModel.ImageUrl" title="@Model.DefaultPictureModel.Title" class="main_product_img"></a>
    </div>
    @{
        var uomattribute = Model.ProductAttributes.Where(x => x.Name == "UOM").FirstOrDefault();
        var controlId = $"{InovatiqaDefaults.ProductAttributePrefix}{uomattribute.Id}";
    }
    <select class="form-control uom_@Model.Id" name="@controlId" id="@(controlId)" style="display: none;">
        @foreach (var attributeValue in uomattribute.Values)
        {
            if (attributeValue == uomattribute.Values.First())
            {
                <option selected="@attributeValue.IsPreSelected" value="@attributeValue.Id" msku="@attributeValue.MSku">@attributeValue.Name</option>
            }
            else
            {
                <option selected="@attributeValue.IsPreSelected" value="@attributeValue.Id" msku="@attributeValue.MSku">@attributeValue.Name</option>
            }

        }
    </select>
    <div class="prod_body">
        <a href="@Url.RouteUrl("Product", new {SeName = Model.SeName})"><h4>@Model.Name</h4></a>
        <p>@(colorOptions == null ? null : colorOptions.Name) @Model.ManufacturerPartNumber</p>
        <h2>@uomMOdel.Name</h2>
        <div class="bottom_ic">
            <h5>@Model.ProductPrice.Price</h5>
            @*<a href="#" onclick="AjaxCart.addproducttocart_catalog('@addtocartlink', @((int)ShoppingCartType.ShoppingCart));return false;" class="btn btn-primary">Buy Now</a>*@
            <input type="hidden" class="qty_@Model.Id" value="1" />
            <a href="#" onclick="AjaxCart.addproducttocart_productlisting('@Url.RouteUrl("AddProductToCart-ProductListing", new { productId = Model.Id, quantity = 1 })', @Model.Id); return false;" class="btn btn-primary">Buy Now</a>
        </div>
    </div>
</div>