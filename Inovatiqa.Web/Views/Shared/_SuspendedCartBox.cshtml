<div class="modal fade" style="height:fit-content;" id="suspend-shopping-cart-box" tabindex="-1" role="dialog" aria-labelledby="Suspend shopping cart" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered" newcustomer-area billing_chang_addres role="document" >
        <div class="modal-content accountform-area font_lato" id="account-deatil" style="border-radius:0;">
            <div class="modal-header" style="margin:0 10px;">
                <h4 class="form-title mt0 mb0" style="margin-left:0;" id="exampleModalLongTitle">Suspend Shopping Cart</h4>
            </div>
            
            <div class="modal-body ml10">
                <form class="createaccount-form mb0" >
                    <div class="row flex_col align_center">
                        <div class="col-md-4 col-sm-3 col-xs-12">
                            <div class="form-group">
                                <label class="">Name / PO Number</label>
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-9 col-xs-12">
                            <div class="form-group">
                                <input type="text" class="form-control" id="suspended-shopping-cart-control" />
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-3 col-xs-12">
                            <div class="form-group">
                                <label class="">Email</label>
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-9 col-xs-12">
                            <div class="form-group">
                                <input type="text" class="form-control" id="suspended-shopping-cart-control-email" />
                            </div>
                        </div>
                        <div class="col-md-4 col-sm-3 col-xs-12">
                            <div class="form-group">
                                <label class="">Comment</label>
                            </div>
                        </div>
                        <div class="col-md-6 col-sm-9 col-xs-12">
                            <div class="form-group">
                                <input type="text" class="form-control" id="suspended-shopping-cart-control-comment" />
                            </div>
                        </div>

                        <div class="col-md-6 col-md-offset-4 col-sm-12 col-xs-12" style="margin-bottom: 0;">
                            <div style="display: flex;">
                                <div class="form-group font_roboto">
                                    <input type="button" id="suspendCart" name="suspendCart" value="Save" class="btn btn-signin" style="width:130px;">
                                </div>
                                <div class="form-group font_roboto">
                                    <input type="button" id="cancelSuspendCart" name="cancelSuspendCart" data-dismiss="modal" style="width:130px;" value="Cancel" class="btn btn-signin">
                                </div>
                            </div>
                        </div>

                    </div>
                   
                </form>
            </div>
        </div>
    </div>
</div>



