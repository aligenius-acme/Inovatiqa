@model AddressModel
<input asp-for="Id" type="hidden" />
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>First name</label>
    <input type="text" class="form-control" asp-for="FirstName" placeholder="First Name"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Last name</label>
     <input type="text" class="form-control" asp-for="LastName" placeholder="Last Name"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Email address</label>
    <input type="text" class="form-control" asp-for="Email" placeholder="Email Address"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Phone number</label>
   <input type="text" class="form-control" asp-for="PhoneNumber" placeholder="Phone Number"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Address</label>
    <input type="text" class="form-control" asp-for="Address1" placeholder="Street Address"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Town / City</label>
    <input type="text" class="form-control" asp-for="City" placeholder="City"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Country</label>
   <select class="form-control" asp-for="CountryId" asp-items="Model.AvailableCountries"
            data-trigger="country-select"
            data-url="@(Url.RouteUrl("GetStatesByCountryId"))"
            data-stateprovince="#@Html.IdFor(model => model.StateProvinceId)"
            data-loading="#states-loading-progress">
    </select>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>State / Province</label>
    <select asp-for="StateProvinceId" asp-items="Model.AvailableStates" class="form-control"></select>
     <span id="states-loading-progress" style="display: none;" class="please-wait">Wait...</span>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>ZIP/Postal code</label>
    <input type="text" class="form-control" asp-for="ZipPostalCode" placeholder="Postal Code"/>
</div>
<div class="col-md-6 col-sm-12 col-xs-12 form-group">
    <label>Company</label>
    <input type="text" class="form-control" asp-for="Company" placeholder="Company"/>
</div>

