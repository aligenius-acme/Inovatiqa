@Html.Resource(@<script type="text/javascript">
                    $(document).ready(function () {
                        applyMini();
                    });

                    $(window).on('resize', function () {
                        applyMini();
                    });

                    function applyMini() {
                        if ($(".cart-small-screen").is(":visible"))
                            $('.nav-top').find('li').css('float', 'none');
                        else
                            $('.nav-top').find('li').css('float', 'left');
                    }
</script>, "js")

