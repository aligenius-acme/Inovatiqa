        @Html.Resource(@<script type="text/javascript">
                            var localized_data = {
                                AjaxCartFailure: "Failed to add the product. Please refresh the page and try one more time."
                            };
                            AjaxCart.init(false, '.header-links .cart-qty', '.header-links .wishlist-qty', '#flyout-cart', localized_data);
        </script>, "js")
        @await Html.PartialAsync("_PaymentHeader")
        @await Html.PartialAsync("_PaymentMenu")

        @if (IsSectionDefined("Breadcrumb"))
        {
            @RenderSection("Breadcrumb")
        }
        @if (IsSectionDefined("additionalMeta"))
        {
            @section additionalMeta {
                @RenderSection("additionalMeta")
            }
        }
        @*ajax loading window*@
        <div class="ajax-loading-block-window" style="display: none">
            <div class="loading-image">
            </div>
        </div>
        <div class="content">
            <div class="row">
                @RenderBody()
            </div>
        </div>
        @Html.Resource(@<script type="text/javascript">
            $(document).ready(function () {
                var cookie = Cookies.get(".Inovatiqa.Accept");
                if(cookie == undefined || cookie == null)
                    $('#eu-cookie-bar-notification').show();
                else
                    $('#eu-cookie-bar-notification').hide();
                $('#eu-cookie-ok').on('click', function () {
                    Cookies.set('.Inovatiqa.Accept', 'true', { expires: 365, secure: true })
                    $('#eu-cookie-bar-notification').hide();
                    @*$.ajax({
                        cache: false,
                        type: "POST",
                        url: "@Url.RouteUrl("EuCookieLawAccept")",
                        dataType: "json",
                        success: function (data, textStatus, jqXHR) {
                            $('#eu-cookie-bar-notification').hide();
                        },
                        error: function (jqXHR, textStatus, errorThrown) {
                            alert('Cannot store value');
                        }
                    });*@
                });
            });
        </script>, "js")
