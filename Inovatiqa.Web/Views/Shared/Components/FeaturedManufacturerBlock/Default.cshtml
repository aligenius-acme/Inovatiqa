@model IList<ManufacturerModel>
@if (Model.Count > 0)
{
    <div class="block block-recently-viewed-products well" style="background-color:#fff;">
        <div class="title page-title panel-heading">
            <h1>Featured brands</h1>
        </div>
                   <div class="listbox" style="display:flex; flex-wrap:wrap">
                    @for (var i = 0; i < Model.Count; i++)
                    {
                        var manufacturer = Model[i];
                        <div @(i == Model.Count - 1 ? @Html.Raw(" class=\"last\"") : null)>
                            @if (!string.IsNullOrEmpty(manufacturer.PictureModel.ImageUrl))
                            {<div style="padding: 5px 0;margin: 0 5px;position: relative;">
                                 <div class="col-12 col-lg-12 col-md-12 col-sm-12">                
                                         <a href="@Url.RouteUrl("Manufacturer", new { SeName = manufacturer.SeName })" title="@manufacturer.PictureModel.Title">
                                             <div class="FMimg">
                                                 <img style="max-width: 100%; max-height: 100%; margin: 0 5px;" alt="@manufacturer.PictureModel.AlternateText" src="@manufacturer.PictureModel.ImageUrl" title="@manufacturer.PictureModel.Title" />
                                             </div>
                                         </a>
                                 </div>
                                    @*<img style="display:inline-block;width:140px; margin-right:10px;margin-top:20px; position:relative" alt="Picture for manufacturer Mckesson" src="/images/thumbs/0000054_mckesson_150.png" title="Show products manufactured by Mckesson">*@
                                </div>
                            }
                        </div>

                    }
                </div>
    </div>
}