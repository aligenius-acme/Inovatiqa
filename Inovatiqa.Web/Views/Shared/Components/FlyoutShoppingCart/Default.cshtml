<div class="cart_menu">
    <div class="cart_head">
        <h3>Your Cart</h3>
        @if (Model.Items.Count == 0)
        {
            <span id="flyoutCount">No items in your cart</span>
        }
        else
        {
            <span id="flyoutCount">@Model.Items.Count items in your cart</span>
        }
    </div>
    <div class="cart_body">
        @foreach (var item in Model.Items)
        {
            <div class="cart_box">
                <img src="@item.Picture.ImageUrl" class="cart_list_img">
                <div>
                    <h4>@item.ProductName</h4>
                    <div class="flex_cart_box">
                        <div>
                            <div class="form-group custom-qty-box">
                                <a href="javascript:void(0)" class="border-button-flyoyt" onclick="AjaxCart.changeQuantity(@item.Id, 'd', '#qty_@item.Id')"><img class="sign-img" src="~/images/UIComponents/minus.svg" alt=""></a>
                                <span class="qty-text" id="qty_@item.Id">@item.Quantity</span>
                                <a href="javascript:void(0)" class="border-button-flyoyt" onclick="AjaxCart.changeQuantity(@item.Id, 'i', '#qty_@item.Id')"><img class="sign-img" src="~/images/UIComponents/plud.svg" alt=""></a>
                            </div>
                        </div>
                        <div>
                            <h2>@item.UnitPrice.Replace("$", "") USD</h2>
                        </div>
                    </div>
                </div>
            </div>
            <hr />
        }
    </div>
    <div class="cart_foot m_t_30">
        <a href="@Url.RouteUrl("ShoppingCart")" class="view-cart">View Cart</a>
        <a href="@Url.RouteUrl("CheckoutOnePage")" class="btn btn-signin">Continue to Payment</a>
    </div>
</div>