@{
    var term = TempData["term"];
    var selectedCategory = TempData["category"];
}
<form asp-route="ProductSearch" method="get" id="small-search-box-form">
    @if (Model.ShowSearchBox)
    {
        <div class="select_box">
            <div class="search_b border_right">
                <img src="/images/UIComponents/downarrow.svg" class="down_arrow" />
                <select class="form-control" name="categoryFilter">
                    <option value="-1">Search Products</option>
                    @foreach(var category in Model.Categories)
                    {
                        <option value="@category.Key" selected="@(category.Key == Convert.ToInt32(selectedCategory))">@category.Value</option>    
                    }
                </select>
            </div>
            <div class="search_input p0">
                <input type="text" class="form-control search_text" id="small-searchterms" autocomplete="off" name="term" placeholder="What are you searching for?" aria-label="Search store" value="@term"/>
                <input type="submit" value="" hidden id="search_btn">
                <img src="/images/UIComponents/ic-actions-search.svg" class="search_icon pointer" onclick="$('#search_btn').click()">
                @if (Model.SearchTermMinimumLength > 0)
                {
                    @Html.Resource(@<script type="text/javascript">
                        $("#small-search-box-form").on("submit", function (event) {
                        if ($("#small-searchterms").val() == "") {
                        @*alert('@Html.Raw(JavaScriptEncoder.Default.Encode("Please enter some search keyword"))');*@
                        displayBarNotification('Please enter search terms in search box.', 'error', 5000)
                        $("#small-searchterms").focus();
                        event.preventDefault();
                        }
                    });
                    </script>, "js")
                }
            </div>
        </div>
    }
</form>














