@model AdminHeaderLinksModel
@if (Model.IsCustomerImpersonated || Model.DisplayAdminLink)
{
    <li class="admin-header-links">
        @if (Model.IsCustomerImpersonated)
        {
            <div class="impersonate">
                <span>@string.Format("Impersonated as {0}", Model.ImpersonatedCustomerName)</span>
                <a href="@Url.RouteUrl("Logout")" class="finish-impersonation" title="Click here to finish impersonated session.">finish impersonated session</a>
            </div>
        }
        @if (Model.DisplayAdminLink)
        {
            <a href="@Url.Content("~/Admin")" class="administration">Administration</a>
        }
    </li>
    if (!string.IsNullOrEmpty(Model.EditPageUrl))
    {
        <li class="admin-header-links">
            <a href="@Model.EditPageUrl" class="manage-page">Manage this page</a>
        </li>
    }
}