@model IList<ProductOverviewModel>

@if (Model.Count > 0)
{
    @if (Model.Count > 0)
    {
        <section class="container-fluid">
            <div class="row">
                <div class="container">
                    <div class="row flex_col   m_b_40">
                        <div class="col-md-12 title_text font_lato">
                            <div class="row flex_col align_center">
                                <div class="col-md-12 col-sm-12 col-xs-12"><h2><strong>Most Viewed </strong>  Products</h2></div>
                            </div>
                        </div>
                        <div class="col-md-12">
                            <div class="row flex_col  ">
                                @foreach (var product in Model)
                                {
                                    <div class="col-md-3 col-sm-6 col-xs-12 flex_col">
                                        @await Html.PartialAsync("_ProductBox", product)
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    }
}