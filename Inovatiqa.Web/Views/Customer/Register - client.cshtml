                                $("#progBtn").on("click", function () {
                                    if ($('#basicUserInfo').valid()) {
                                        var type = $("#RegisterType").val();
                                        if (type == "vendorType") {
                                            $("#step1").hide();
                                            $("#step2").hide();
                                            $("#step5").hide();
                                            $("#Venstep2").show();
                                            $("#companyInfo").show();
                                            $("#comInfo").addClass("active");
                                            $("#billingInfo").hide();
                                            $("#shippingInfo").hide();
                                            $("#customerInfo").hide();
                                            $("#careSettings").hide();

                                        }
                                        else if (type == "customerType") {
                                            $("#step1").hide();
                                            $("#step2").show();
                                            $("#Venstep2").hide();
                                            $("#step5").hide();

                                        }
                                        else {
                                            $("#step1").show();
                                            $("#step2").hide();
                                            $("#Venstep2").hide();
                                            $("#step5").hide();

                                        }
                                    }
                                    else {
                                        return false;
                                    }
                                });
