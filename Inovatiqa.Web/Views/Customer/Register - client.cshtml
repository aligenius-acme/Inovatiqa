                            <h1>Yes! I would like to Become a Customer.</h1>
                            <div class="form-group ">
                                <label for="RegisterType" class="control-label">Tell us about yourself</label>
                                <select id="RegisterType" name="RegisterType" class="form-control">
                                    <option value=""> Please Select One...</option>
                                    <option id="vendorType" value="vendorType"> I'm a Medical Professional or Administrator</option>
                                    <option id="customerType" value="customerType"> I'm a Customer that is ordering for personal use</option>
                                </select>
                            </div>
                            <div class="form-group  error-group-fullName">
                                <label for="FirstName" class="control-label ">Full Name </label><span class="required">*</span>
                                <input type="text" class="form-control" value="@Model.FirstName" name="FirstName" id="FirstName" data-val="true" data-val-required="Name is required." maxlength="30" />
                                <span class="field-validation-valid" data-valmsg-for="FirstName" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group  error-group-email">
                                <label for="email" class="control-label ">Email Address </label><span class="required">*</span>
                                <input class="form-control" type="email" data-val="true" value="@Model.Email" data-val-email="Wrong email" data-val-required="Email is required." id="Email" name="Email">
                                <span class="field-validation-valid" data-valmsg-for="Email" data-valmsg-replace="true"></span>
                            </div>
                            <div class="form-group  error-group-password">
                                <label for="phone" class="control-label">Password </label><span class="required">*</span>
                                <span class="field-validation-valid" data-valmsg-for="Password" data-valmsg-replace="true"></span>
                                <input class="form-control" type="password" data-val="true" value="@Model.Password" data-val-regex="<ul><li>must have at least 6 characters</li></ul>" data-val-regex-pattern="^.{6,}$" data-val-required="Password is required." id="Password" name="Password">
                            </div>
                            <div class="form-group  error-group-Con-password">
                                <label for="phone" class="control-label">Confirm Password </label><span class="required">*</span>
                                <input class="form-control" type="password" data-val="true" value="@Model.ConfirmPassword" data-val-equalto="The password and confirmation password do not match." data-val-equalto-other="*.Password" data-val-required="Confirm Password is required" id="Confirm_Password" name="Confirm Password">
                                <span class="field-validation-valid" data-valmsg-for="Confirm Password" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    </div>
                </div>
