@model RegisterModel
@{
    Layout = "_ColumnsOne";
}
@{
    ViewBag.Title = "Register";
}
<form asp-route="Register" asp-route-returnurl="@Context.Request.Query["ReturnUrl"]" method="post" autocomplete="off">
    <div class="page registration-page from-panel">
        <div class="page-title panel-heading">
            <h1>Register</h1>
        </div>
        <div class="page-body form-horizontal panel-body">
            <div asp-validation-summary="ModelOnly" class="message-error"></div>
            <div class="inputs custom-attributes" style="text-align:center;">
                <div class="form-group">
                    <label class="control-label col-sm-3 col-md-4 col-xs-12" style="visibility:hidden;">Type:</label>
                    <div class="col-sm-6 col-md-4 col-xs-12" style="text-align:center;">
                        <ul class="option-list" style="margin-top:7px;">
                            <li style="display:inline;">
                                <input id="customerType" type="radio" name="RegisterType">
                                <label for="customerType">Customer</label>
                            </li>
                            <li style="display:inline;margin-left:50px">
                                <input id="vendorType" type="radio" name="RegisterType">
                                <label for="vendorType">Vendor</label>
                            </li>
                        </ul>
                    </div>
                    @Html.Resource(@<script type="text/javascript">
                                        $(document).ready(function () {
                                            var url = window.location.href;
                                            if (url.indexOf("vendor") != -1) {
                                                $('#vendorType').attr("checked", "checked")
                                                $('.vendorSection:not(:first)').hide();
                                                $("#next-button").show();
                                                $("#previous-button").hide();
                                                $("#register-button").hide();
                                            }
                                            else {
                                                $('#customerType').attr("checked", "checked")
                                                $("#next-button").hide();
                                                $("#previous-button").hide();
                                            }
                                            $('#customerType').on('click', function () {
                                                url = url.replace("/vendor", "")
                                                if (url.indexOf("customer") == -1) {
                                                    var urlSplit = url.split('?');
                                                    url = urlSplit[0] + "/customer?" + urlSplit[1];
                                                    window.location.href = url;
                                                }
                                                else
                                                    window.location.href = url;
                                            });
                                            $('#vendorType').on('click', function () {
                                                url = url.replace("/customer", "")
                                                if (url.indexOf("vendor") == -1) {
                                                    var urlSplit = url.split('?');
                                                    url = urlSplit[0] + "/vendor?" + urlSplit[1];
                                                    window.location.href = url;
                                                }
                                                else
                                                    window.location.href = url;
                                            });
                                        });
                    </script>, "js")
                </div>
            </div>
            <div id="generalInformation" class="vendorSection">
                <div class="fieldset">
                    <div id="legend">
                        <legend>Personal Information</legend>
                    </div>
                    @if (Model.FirstNameEnabled)
                    {
                        <div class="form-group">
                            <label class="control-label col-sm-3 col-md-4 col-xs-12">First name:</label>
                            <div class="col-sm-6 col-md-4 col-xs-12">
                                <input class="form-control" type="text" data-val="true" data-val-required="First name is required." id="FirstName" name="FirstName">
                            </div>
                            <div class="col-sm-3 col-md-4 col-xs-12">
                                @if (Model.FirstNameRequired)
                                {
                                    <span class="required">*</span>
                                }
                                <span class="field-validation-valid" data-valmsg-for="FirstName" data-valmsg-replace="true"></span>
                            </div>
                        </div>
                    }
