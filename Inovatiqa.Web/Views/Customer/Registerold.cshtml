                                        <span class="required">*</span>
                                    }
                                    <span class="field-validation-valid" data-valmsg-for="Fax" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (Model.NewsletterEnabled)
                {
                    <div class="fieldset">
                        <div id="legend"><legend>Options</legend></div>
                        @if (Model.NewsletterEnabled)
                        {
                            <div class="form-group">
                                <label class="col-sm-3 col-md-4 col-xs-5  news-letter control-label">Newsletter:</label>
                                <div class="col-sm-6 col-md-4 col-xs-3">
                                    <input type="checkbox" checked="" data-val="true" data-val-required="The Newsletter field is required." id="Newsletter" name="Newsletter" value="true">
                                </div>
                                <span class="field-validation-valid" data-valmsg-for="Newsletter" data-valmsg-replace="true"></span>
                            </div>
                        }
                    </div>
                }
            </div>
            @if (Model.IsCustomerRegistration == false)
            {
                <div class="vendorSection" id="companyInformation">
                    @if (Model.CompanyEnabled)
                    {
                        <div class="fieldset">
                            <div id="legend"><legend>Company Information</legend></div>
                            <div class="form-group">
                                <label class="control-label col-sm-3 col-md-4 col-xs-12">Legal Company name:</label>
                                <div class="col-sm-6 col-md-4 col-xs-12">
                                    <input class="form-control" type="text" data-val="true" data-val-required="Company name is required" id="Company" name="Company">
                                </div>
                                <div class="col-sm-3 col-md-4 col-xs-12">
                                    @if (Model.CompanyRequired)
                                    {
                                        <span class="required">*</span>
                                    }
                                    <span class="field-validation-valid" data-valmsg-for="Company" data-valmsg-replace="true"></span>
                                </div>
                            </div>
                        </div>
                    }
                    @if (Model.CustomerAttributes.Count > 0)
                    {
                        <div class="fieldset">
                            @*<div id="legend"><legend>Custom Fields Title 1</legend></div>*@
                            <div class="form-fields">
                                @if (Model.CustomerAttributes.Count > 0)
                                {
                                    @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 0 }, { "endIndex", 5 } })
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="vendorSection" id="references">
                    @if (Model.CustomerAttributes.Count > 0)
                    {
                        <div class="fieldset">
                            <div id="legend"><legend>References</legend></div>
                            <div class="form-fields">
                                @if (Model.CustomerAttributes.Count > 0)
                                {
                                    @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 6 }, { "endIndex", 13 } })
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="vendorSection" id="healthcare">
                    @if (Model.CustomerAttributes.Count > 0)
                    {
                        <div class="fieldset">
                            <div id="legend"><legend>Healthcare</legend></div>
                            <div class="form-fields">
                                @if (Model.CustomerAttributes.Count > 0)
                                {
                                    @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 14 }, { "endIndex", 20 } })
                                }
                            </div>
                        </div>
                    }
                </div>

                <div class="vendorSection" id="education">
                    @if (Model.CustomerAttributes.Count > 0)
                    {
                        <div class="fieldset">
                            <div id="legend"><legend>Education</legend></div>
                            <div class="form-fields">
                                @if (Model.CustomerAttributes.Count > 0)
                                {
                                    @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 21 }, { "endIndex", 21 } })
                                }
                            </div>
                        </div>

                    }
                </div>

                <div class="vendorSection" id="municipalities">
                    @if (Model.CustomerAttributes.Count > 0)
                    {

                        <div class="fieldset">
                            <div id="legend"><legend>Corporate / Municipalities</legend></div>
                            <div class="form-fields">
                                @if (Model.CustomerAttributes.Count > 0)
                                {
                                    @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 22 }, { "endIndex", 22 } })
                                }
                            </div>
                        </div>
                    }
                </div>
            }
            @if (Model.AcceptPrivacyPolicyEnabled)
            {
                <div class="fieldset">
                    <div id="legend">
                        <legend>User agreement</legend>
                    </div>
                    <div class="form-fields">
                        @if (Model.AcceptPrivacyPolicyEnabled)
                        {
                            @Html.Resource(@<script type="text/javascript">
                                $(document).ready(function () {
                                    $('#register-button').on('click', function () {
                                        if ($('#accept-consent').is(':checked')) {
                                            //do some stuff
                                            return true;
                                        }
                                        else {
                                            //just show validation errors, dont post
                                            alert('@Html.Raw(JavaScriptEncoder.Default.Encode("Please accept privacy policy"))');
                                            return false;
                                        }
                                    });
                                });
                            </script>, "js")
                            <div class="form-group">
                                <div class="col-sm-offset-3 col-md-offset-4 col-md-8 col-xs-12">
                                    <div class="accept-privacy-policy accept-consent">
                                        <input id="accept-consent" type="checkbox" name="accept-consent" />
                                        <label for="accept-consent">I accept privacy policy</label>
                                        @if (Model.AcceptPrivacyPolicyPopup)
                                        {
                                            <span class="read" id="read-privacyinfo">(read)</span>
                                            @Html.Resource(@<script type="text/javascript">
                                                $(document).ready(function() {
                                                    $('#read-privacyinfo').on('click', function (e) {
                                                        displayPopupContentFromUrl('@Url.RouteUrl("TopicPopup", new { SystemName = "privacyinfo" })', "I accept privacy policy");
                                                    });
                                                });
                                            </script>, "js")
                                        }
                                        else
                                        {
                                            @*<a class="read" id="read-privacyinfo" href="@Url.RouteUrl("Topic", new {SeName = Html.GetTopicSeName("privacyinfo") })">(read)</a>*@
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            }
            @Html.Resource(@<script type="text/javascript">
                                $(document).ready(function () {
                                    $('#next-button').on('click', function () {
                                        var currentSectionId = $(".vendorSection").not(":hidden").prop("id");
                                        var nextSectionId = "";
                                        var previousSectionId = "";

                                        if (currentSectionId == "generalInformation") {
                                            nextSectionId = "#companyInformation";
                                            previousSectionId = "#generalInformation";
                                            $('#previous-button').show();
                                        }
                                        else {
                                            $('#previous-button').show();
                                            nextSectionId = "#" + $("#" + currentSectionId).next().prop("id");
                                            previousSectionId = "#" + $("#" + currentSectionId).prop("id");
                                        }

                                        if (nextSectionId == "#municipalities") {
                                            $(this).hide();
                                            $('#register-button').show();
                                        }

                                        handleSection(nextSectionId, previousSectionId, "Next")
                                    });

                                    $('#previous-button').on('click', function () {
                                        var currentSectionId = $(".vendorSection").not(":hidden").prop("id");
                                        var nextSectionId = "";
                                        var previousSectionId = "";

                                        if (currentSectionId == "municipalities") {
                                            nextSectionId = "#municipalities";
                                            previousSectionId = "#education";
                                        }
                                        else {
                                            $('#register-button').hide();
                                            nextSectionId = $("#" + currentSectionId).prop("id");
                                            previousSectionId = $("#" + currentSectionId).prev().prop("id");
                                        }

                                        if (previousSectionId == "#generalInformation") {
                                            $(this).hide();
                                            $('#register-button').hide();
                                        }

                                        handleSection(nextSectionId, previousSectionId, "Previous")
                                    });

                                    function handleSection(nextSectionId, previousSectionId, buttonType) {
                                        if (buttonType == "Next") {
                                            $(previousSectionId).hide();
                                            $(nextSectionId).show();
                                        }
                                        else if (buttonType == "Previous") {
                                            $(previousSectionId).show();
                                            $(nextSectionId).hide();
                                        }
                                    }
                                });
            </script>, "js")
            <div class="form-group">
                <div class="col-sm-offset-3 col-md-offset-4 col-md-8 col-xs-12">
                    <input type="submit" id="register-button" class="btn btn-primary register-next-step-button" value="Register" name="register-button" />
                    <input type="button" id="previous-button" class="btn btn-primary vendor-previous-step-button" value="Previous" name="previous-button" style="display:none;" />
                    <input type="button" id="next-button" class="btn btn-primary vendor-next-step-button" value="Next" name="next-button" style="display:none;" />
                </div>
            </div>
            @*<div class="external-authentication">
                    @await Component.InvokeAsync("ExternalMethods", "ExternalAuthentication")
                </div>*@
        </div>
    </div>
    @Html.AntiForgeryToken()
</form>

