@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@
<section class="container-fluid deshboard_section">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-3 col-sm-5">
                    <div class="sidebar_menu font_lato">
                        <h3>Inovatiqa Dashboard</h3>
                        @await Html.PartialAsync("_DashboardSideBar", "my-account")
                    </div>
                </div>
                <div class="col-md-9 col-sm-7">
                    <div class="information_account font_lato">
                        <p>
                            From your Dashboard, you have the ability to view your recent account activity. <br>
                            Select a link below to view the following:
                        </p>
                        <h4>Account Information</h4>
                        <hr class="line">
                        <div class="Account Information">
                            <div class="row">
                                <div class="col-md-6 col-sm-6">
                                    <div class="one_col">
                                        <h4>Account Information</h4>
                                        <p><a href="@Url.RouteUrl("accountinfoedit")">Edit</a></p>
                                        <h4>@Model.FirstName</h4>
                                        <h4>@Model.Email</h4>
                                        <p><a href="@Url.RouteUrl("CustomerChangePassword")">Change Password</a></p>
                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-6">
                                    <div class="one_col">
                                        <h4>Newsletters</h4>
                                        <p><a href="#">Edit</a></p>
                                        <p><a href="#">You are currently not subscribed to any newsletter.</a></p>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <h4>Address</h4>
                        <hr class="line">
                        <div class="Account Information">
                            <div class="row">
                                <div class="col-md-6 col-sm-6">
                                    <div class="one_col">
                                        <h4>Default Billing Address</h4>
                                        <p><a href="@Url.RouteUrl("BillingAddressList")">Edit</a></p>
                                        @if (Model.BillingAddress != null)
                                        {
                                            <h4>@Model.BillingAddress.FirstName @Model.BillingAddress.LastName</h4>
                                            <h4>@Model.BillingAddress.Address1</h4>
                                            <h4>@Model.BillingAddress.City, @(Model.BillingAddress.StateProvince != null ? Model.BillingAddress.StateProvince.Abbreviation : "N/A"), @Model.BillingAddress.ZipPostalCode</h4>
                                            <h4>@Model.BillingAddress.Country</h4>
                                            <h4>T: @Model.BillingAddress.PhoneNumber</h4>
                                        }
                                        else
                                        {
                                            <h4>Billing address does not exists</h4>
                                        }

                                    </div>
                                </div>
                                <div class="col-md-6 col-sm-6">
                                    <div class="one_col">
                                        <h4>Default Shipping Address</h4>
                                        <p><a href="@Url.RouteUrl("ShippingAddressList")">Edit</a></p>
                                        @if (Model.ShippingAddress != null)
                                        {
                                            <h4>@Model.ShippingAddress.FirstName @Model.ShippingAddress.LastName</h4>
                                            <h4>@Model.ShippingAddress.Address1</h4>
                                            <h4>@Model.ShippingAddress.City, @(Model.ShippingAddress.StateProvince != null ? Model.ShippingAddress.StateProvince.Abbreviation : "N/A"), @Model.ShippingAddress.ZipPostalCode</h4>
                                            <h4>@Model.ShippingAddress.Country</h4>
                                            <h4>T: @Model.ShippingAddress.PhoneNumber</h4>
                                        }
                                        else
                                        {
                                            <h4>Shipping address does not exists</h4>
                                        }

                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>