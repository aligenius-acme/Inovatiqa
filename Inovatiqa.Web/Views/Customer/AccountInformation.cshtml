    <script>
        $(document).ready(function () {
            if (!isUserLoggedIn === true) {
                document.location.href('/');
            }
        });
        function handlePasswordVisibility() {
            $('#passwordDiv').toggle();
            $('#password').prop('disabled') ? $('#password').prop('disabled', false) : $('#password').prop('disabled', true);
            $('#confirmPasswordDiv').toggle();
            $('#confirmPassword').prop('disabled') ? $('#confirmPassword').prop('disabled', false) : $('#confirmPassword').prop('disabled', true);
        }
        function handleEmailVisibility() {
            $('#emailDiv').toggle();
