@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@
<section class="container-fluid deshboard_section">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="sidebar_menu font_lato">
                        <h3>Inovatiqa Dashboard</h3>
                        @await Html.PartialAsync("_DashboardSideBar", "manage-sub-accounts")
                    </div>
                </div>
                <div class="col-md-9 newcustomer-area billing_chang_addres ">
                    <div class="accountform-area font_lato" id="account-deatil">
                        <div class="form-title">
                            <h5>Manage Sub-Accounts</h5>
                        </div>
                        <hr class="line">
                        @if (Model.Accounts.Count > 0)
                        {
                            <div class="row">
                                <div class="col-md-7 col-sm-7">
                                    <div class="user_details">
                                        <div class="form-group">
                                            <label>User Name</label>
                                            @foreach (var account in Model.Accounts)
                                            {
                                                <input type="email" class="form-control" value="@account.Name" disabled style="cursor: inherit;">
                                                <hr style="opacity: 0" />
                                            }

                                        </div>
                                    </div>
                                </div>
                                <div class="col-md-5 col-sm-5">
                                    <div class="option_select">
                                        <h3>Options</h3>
                                        @foreach (var account in Model.Accounts)
                                        {
                                            <a onclick="Delete(@account.Id)" class="btn primary edit font_roboto danger">Delete</a>
                                            <a href="@Url.ActionLink("AddSubAccount", "Customer", new { isEditing = true, ChildId=account.Id })" class="btn primary edit font_roboto">Edit</a>
                                            <hr style="opacity: 0" />
                                        }


                                    </div>
                                </div>
                            </div>
                        }
                        else
                        {
                            <div style="display: flex; justify-content: space-between;">
                                <span class="col-md-4" style="border: 1px solid #D1D1D1; border-radius: 1px; background-color: #F0FFDD;">
                                    <span style="padding-right:10px;"><i class="fa fa-exclamation-triangle"></i></span>There are no Sub-Accounts yet.
                                </span>
                            </div>
                        }

                        <div class="form-title add_sub_account">
                            <hr class="line">
                            <a href="@Url.RouteUrl("AddSubAccount")" class="btn primary edit font_roboto">Add Sub-Account</a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script src="https://code.jquery.com/jquery-3.6.0.min.js" integrity="sha256-/xUj+3OJU5yExlq6GSYGSHk7tPXikynS7ogEvDej/m4=" crossorigin="anonymous"></script>
<script>
    $(document).ready(function () {
        if (!isUserLoggedIn()) {
            window.location.href = '/';
        }
    });
    function Delete(id) {
        var action = confirm("This action will delete Acoount Permanently. Do you wish to continue?");
        if (action) {
            $.ajax({
                url: '/Customer/DeleteChildAccount/',
                async: false,
                cache: false,
                data: { Id: id },
                metod: 'POST',
                success: (response) => {
                    location.reload();
                },
                error: (response) => {
                    alert('Server Encountered An Error while Trying to delete the user');
                }
            });
        }
    }
</script>