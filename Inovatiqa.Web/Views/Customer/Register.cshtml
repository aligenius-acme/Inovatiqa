                                            <div class="col-sm-6 col-md-4 col-xs-12">
                                                <input class="form-control" type="text" data-val="true" data-val-required="Phone No is required" value="@Model.BillToPhone" data-val-regex-pattern="^\s*(?:\+?(\d{1,3}))?[-. (]*(\d{3})[-. )]*(\d{3})[-. ]*(\d{4})(?: *x(\d+))?\s*$" data-val-regex="Not a valid phone number" id="BillToPhone" name="BillToPhone">
                                            </div>
                                            <div class="col-sm-3 col-md-4 col-xs-12">
                                                <span class="required">*</span>
