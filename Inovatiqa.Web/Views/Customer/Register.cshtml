                                        <div class="form-fields">
                                            @if (Model.CustomerAttributes.Count > 0)
                                            {
                                                @await Html.PartialAsync("_CustomerAttributes", Model.CustomerAttributes, new ViewDataDictionary(this.Vi‌​ewData) { { "startIndex", 0 }, { "endIndex", 2 } })
