<script>

    $(document).ready(function(){
        $('#agreement').click(function () {
            if ($(this).is(':checked')) {
                $('#termsCheckbox').val('Accepted');
            }
            else {
                $('#termsCheckbox').val('');
            }
        });
        $('select').on('change', function (e) {
            if (e.target.value !== "") {
                $('#formcontinue').removeAttr("style");
            }
            else {
                $('#formcontinue').attr("style", "background-color: #C4C4C4 !important");
                $('#account-details').hide();
                $('#passwordArea').hide();
                $('#alternate_shipping_form').hide();
            }
        });
        //if ($('#IsSameShipToAddress').prop("checked") == true) {
        //    $('#submit').click(function(e) {
        //        e.preventDefault();
        //        if ($('#shipToCity').value == "")
        //            $('#shipToCitySpan').show();

        //    });
        //}
    });
</script>

