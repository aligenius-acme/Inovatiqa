                                            <label class="control-label col-sm-3 col-md-4 col-xs-12">City:</label>
                                            <div class="col-sm-6 col-md-4 col-xs-12">
                                                <input class="form-control" type="text" data-val="true" data-val-required="City is required" value="@Model.BillToCity" id="BillToCity" name="BillToCity">
                                            </div>
                                            <div class="col-sm-3 col-md-4 col-xs-12">
                                                <span class="required">*</span>
                                                <span class="field-validation-valid" data-valmsg-for="City" data-valmsg-replace="true"></span>
                                            </div>
                                        </div>
                                        <div class="form-group row">
                                            <label class="control-label col-sm-3 col-md-4 col-xs-12">Zip / postal code:</label>
                                            <div class="col-sm-6 col-md-4 col-xs-12">
