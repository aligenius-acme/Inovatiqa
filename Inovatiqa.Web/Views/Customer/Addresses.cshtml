@model CustomerAddressListModel
@{
    Layout = "_ColumnsOne";

   ViewBag.Title = "Account";
}
<style>
   .card{
       width: 45%;
   }
    .main-addresses{
        display: flex;
        width: 100%;
        justify-content: space-between;
    }
    .card-body{
        margin: 5% 5% 5% 5%;
    }
    .additional-addresses {
    }
</style>
<h3>Address Book</h3>
<div class="page account-page address-list-page">
    <h4>Default Addresses</h4>
    <div class="page-body">
        <nop-antiforgery-token />
        <div class="main-addresses">
            @if (Model.Addresses.Count > 0)
            {
                @foreach (var address in Model.Addresses)
                {
                    @if (address.IsBillingAddress)
                    {
                        <div class="card bg-success left">
                            <div class="card-body">
                                <h4>Billing Address</h4>
                                <div class="section address-item">
                                    <div class="title">
                                        <strong>@address.FirstName @address.LastName</strong>
                                    </div>
                                    <div class="info">
                                        <div class="name">
                                            @address.FirstName @address.LastName
                                        </div>
                                        @if (false)
                                            {
                                                <div class="email">
                                                    <label>Email:</label>
                                                    @address.Email
                                                </div>
                                             }
                                        <div class="phone">
                                            <label>Phone number:</label>
                                            @address.PhoneNumber
                                        </div>
                                        <div class="fax">
                                            <label>Fax number:</label>
                                            @address.FaxNumber
                                        </div>
                                        <div class="company">
                                            @address.Company
                                        </div>
                                        <div class="address1">
                                            @address.Address1
                                        </div>
                                        <div class="address2">
                                            @address.City, @address.StateProvinceName, @address.ZipPostalCode
                                        </div>
                                    </div>
                                    <div class="buttons">
                                        <input type="button" @(Model.canEditMainAddresses ? null : "disabled") style="margin-top: 5px;" class="btn btn-success" onclick="location.href = '/customer/addressedit?addressId=@address.Id'" value="Edit" />
                                        @*<input type="button" @(Model.canEditMainAddresses ? null : "disabled") style="margin-top: 5px;" class="btn btn-danger" onclick="deletecustomeraddress(@address.Id)" value="Delete" />*@
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    @if (address.IsShippingAddress)
                    {
                        <div class="card bg-success left">
                            <div class="card-body">
                                <h4>Shipping Address</h4>
                                <div class="section address-item">
                                    <div class="title">
                                        <strong>@address.FirstName @address.LastName</strong>
                                    </div>
                                    <div class="info">
                                        <div class="name">
                                            @address.FirstName @address.LastName
                                        </div>
                                    </div>
                                    @if (false)
                                    {
                                        <div class="email">
                                            <label>Email:</label>
                                            @address.Email
                                        </div>
                                    }

                                    <div class="phone">
                                        <label>Phone number:</label>
                                        @address.PhoneNumber
                                    </div>
                                    <div class="fax">
                                        <label>Fax number:</label>
                                        @address.FaxNumber
                                    </div>
                                    <div class="company">
                                        @address.Company
                                    </div>
                                    <div class="address1">
                                        @address.Address1
                                    </div>
                                    <div class="address2">
                                        @address.City, @address.StateProvinceName, @address.ZipPostalCode
                                    </div>
                                </div>
                                <div class="buttons">
                                    <input type="button" @(Model.canEditMainAddresses ? null : "disabled") style="margin-top: 5px;" class="btn btn-success" onclick="location.href = '/customer/addressedit?addressId=@address.Id'" value="Edit" />
                                    <input type="button" @(Model.canEditMainAddresses ? null : "disabled") style="margin-top: 5px;" class="btn btn-danger" onclick="deletecustomeraddress(@address.Id, @address.CustomerId)" value="Delete" />
                                </div>
                            </div>
                        </div>
                    }
                }
            }
        </div>
        <hr />
        <h4>Additional Address Entries</h4>
        <div class="additional-addresses">
            @if (Model.Addresses.Count > 0)
            {
                foreach (var address in Model.Addresses)
                {
                    @if (!address.IsBillingAddress && !address.IsShippingAddress)
                    {
                        <div class="card bg-info left">
                            <div class="card-body">
                                <h4>Shipping Address</h4>
                                <div class="section address-item">
                                    <div class="title">
                                        <strong>@address.FirstName @address.LastName</strong>
                                    </div>
                                    <div class="info">
                                        <div class="name">
                                            @address.FirstName @address.LastName
                                        </div>
                                    </div>
                                    @if (false)
                                    {
                                        <div class="email">
                                            <label>Email:</label>
                                            @address.Email
                                        </div>
                                    }

                                    <div class="phone">
                                        <label>Phone number:</label>
                                        @address.PhoneNumber
                                    </div>
                                    <div class="fax">
                                        <label>Fax number:</label>
                                        @address.FaxNumber
                                    </div>
                                    <div class="company">
                                        @address.Company
                                    </div>
                                    <div class="address1">
                                        @address.Address1
                                    </div>
                                    <div class="address2">
                                        @address.City, @address.StateProvinceName, @address.ZipPostalCode
                                    </div>
                                </div>
                                <div class="buttons">
                                    <input type="button" style="margin-top: 5px;" class="btn btn-success" onclick="location.href = '/customer/addressedit?addressId=@address.Id &customerId=@address.CustomerId'" value="Edit" />
                                    <input type="button" style="margin-top: 5px;" class="btn btn-danger" onclick="deletecustomeraddress(@address.Id, @address.CustomerId)" value="Delete" />
                                </div>
                            </div>
                        </div>
                     }
                }
             }
            </div>
