@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@
<section class="container-fluid deshboard_section">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="sidebar_menu font_lato">
                        <h3>Inovatiqa Dashboard</h3>
                        @await Html.PartialAsync("_DashboardSideBar", "my-account")
                    </div>
                </div>
                <div class="col-md-9 newcustomer-area billing_chang_addres">
                    <div class="accountform-area font_lato" id="account-deatil">
                        <div class="form-title">
                            <h5>Change Password</h5>
                        </div>
                        <hr class="line">
                        <form class="createaccount-form" asp-route="CustomerChangePassword" method="post" autocomplete="off">
                            @if (!string.IsNullOrEmpty(Model.Result))
                            {
                                @if (Model.Result == "Success")
                                {
                                    <div class="alert alert-success" role="alert" style="border-radius: 0px; display: flex; justify-content: center;">
                                        Password Changed Successfully.
                                    </div>
                                }
                                else
                                {
                                    <div class="alert alert-danger" role="alert" style="border-radius: 0px; display: flex; justify-content: center;">
                                        @Model.Result
                                    </div>
                                }

                            }
                            <div class="row flex_col align_center">
                                <div class="col-md-3 col-sm-3 col-xs-12">
                                    <div class="form-group">
                                        <label class="">Current Password</label>
                                    </div>
                                </div>
                                <div class="col-md-9 col-sm-9 col-xs-12">
                                    <div class="form-group">
                                        <input class="form-control" asp-for="OldPassword" />
                                        <span asp-validation-for="OldPassword"></span>
                                    </div>
                                </div>
                                <div class="col-md-3 col-sm-3 col-xs-12">
                                    <div class="form-group">
                                        <label class="">New Password</label>
                                    </div>
                                </div>
                                <div class="col-md-9 col-sm-9 col-xs-12">
                                    <div class="form-group">
                                        <input class="form-control" asp-for="NewPassword" />
                                        <span asp-validation-for="NewPassword"></span>
                                    </div>
                                </div>
                                <div class="col-md-3 col-sm-3 col-xs-12">
                                    <div class="form-group">
                                        <label class="">Enter New Password</label>
                                    </div>
                                </div>
                                <div class="col-md-9 col-sm-9 col-xs-12">
                                    <div class="form-group">
                                        <input class="form-control" asp-for="ConfirmNewPassword" />
                                        <span asp-validation-for="ConfirmNewPassword"></span>
                                    </div>
                                </div>



                                <div class="col-md-9 col-md-offset-3 col-sm-12 col-xs-12">
                                    <div class="form-group font_roboto">
                                        <input type="submit" value="Save Changes" class="btn btn-signin" />
                                    </div>
                                </div>
                            </div>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>