<section class="container-fluid orderstatus-area">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="dashboard-area">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="sidebar_menu font_lato">
                                    <h3>Inovatiqa Dashboard</h3>
                                    @await Html.PartialAsync("_DashboardSideBar", "inovatiqa-returns")
                                </div>
                            </div>

                            <div class="col-md-9">
                                <div class="order-deatil-area s step-one submitrequest step-four">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="tabs font_lato" style="max-width: unset;">
                                                <ul>
                                                    <li><a href="#" class="previous-check active">Step One</a></li>
                                                    <li><a href="#" class="previous-check active" data-toggle="modal" data-target="#step-returnpopup" data-backdrop="false">Step Two</a></li>
                                                    <li><a href="#" class="previous-check active">Step Three</a></li>
                                                    <li><a href="#" class="previous-check active">Step Four</a></li>
                                                    <li><a href="#" class="previous-check active">Step Five</a></li>
                                                </ul>

                                                <hr>
                                            </div>

                                        </div>

                                        <div class="col-md-12">
                                            <div class="order-content">


                                                <div class="cancel-req-btns font_roboto text-right">
                                                    <a href="@Url.RouteUrl("CustomerReturnRequests")" class="btn continue-btn">Finish</a>
                                                </div>

                                                <div class="items-table-area table-responsive font_roboto">
                                                    <table class="table">
                                                        <thead>
                                                            <tr>
                                                                <td style="width: 20%; padding-left: 38px !important;">Return Number</td>
                                                                <td style="width: 165px;">Date & Time</td>
                                                                <td>Invoice Date</td>
                                                                <td>Completed By</td>
                                                                <td style="width: 165px;">Total Pending Credit</td>
                                                            </tr>
                                                        </thead>
                                                        <tbody>
                                                            <tr>
                                                                <td style="padding-left: 38px !important;">@Model.ReturnNo</td>
                                                                <td style="max-width: 90px;">@DateTime.Now.ToString().ToUpper()</td>
                                                                <td>@Model.InvoiceDate</td>
                                                                <td>Inovatiqa Admin</td>
                                                                <td>$ @Model.SelectedItemsPrice.ToString("#.##")</td>

                                                            </tr>
                                                        </tbody>
                                                    </table>
                                                </div>



                                                <div>
                                                    <h5>What you should expect</h5>
                                                    <div class="category_box" style="border: none;">
                                                        <ul>
                                                            <li style="color: black; text-transform: none;">Return may require review and approval. If your return requires additional information or your return denied, customer support will contact you.</li>
                                                            <li style="color: black; text-transform: none;">Inovatiqa will email return labels</li>
                                                            <li style="color: black; text-transform: none;">Credit will be issued to your account upon receipt of the item(s) into our warehouse</li>
                                                            <li style="color: black; text-transform: none;">If you have any questions, please contact customer support at 0800 00 00 00</li>
                                                        </ul>

                                                    </div>
                                                </div>
                                                <div>
                                                    <h5>Shipping Options</h5>
