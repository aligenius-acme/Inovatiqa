<script>
    function UpdateQty(id, value) {
        $(`#${id}`).val(value);
    }

    function validateQuantityInput(component, quantity) {
        const val = component.value;
        if (isNaN(val)) {
            component.value = quantity;
        }
        if (parseInt(val) > quantity) {
            component.value = quantity;
        }
    }
    function validate() {
        return false;
    }

    $(document).ready(function () {
        const dt = $('#returnTable').DataTable({
            "language": {
                "info": '<div class="tpage-num"><p>Showing _START_ to _END_ of _TOTAL_ Items</p></div>'
            },
            "pageLength": 5,
            "dom": 't<"jqueryPagination"ip>',
            'pagingType': 'numbers'
        });
        function filterByColumn() {
            dt
                .search(this.value)
                .draw();
        }
        $('#POName').keyup(filterByColumn);
        $('#invoiceId').keyup(filterByColumn);
        $('#orderId').keyup(filterByColumn);
        $('#itemNumber').keyup(filterByColumn);

        let searchParams = new URLSearchParams(window.location.search);
                        $('.date-picker').datepicker();
                        $('.ui-datepicker').css('font-size', '11px');
                        $('#returnItemFind').click(function() {
                            reloadWithParams();
                        });
                        $('#returnItemClear').click(function() {
                            setLocation('@Url.Action("SelectItems", "ReturnRequest")');
                        });
                        if (searchParams.has('startDateValue') && searchParams.has('endDateValue')) {
                            $("#fromdate").val(searchParams.get('startDateValue'));
                            $("#todate").val(searchParams.get('endDateValue'));
                            $('#pageTitle').append(" " + searchParams.get('startDateValue') + " to " + searchParams.get('endDateValue'));
                            $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("StartDate", searchParams.get('startDateValue')));
                            $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("EndDate", searchParams.get('endDateValue')));
                        }
                        else {
                            var dateOffset = (24 * 60 * 60 * 1000) * 35;
                            var myDate = new Date();
                            myDate.setTime(myDate.getTime() - dateOffset);
                            $('#pageTitle').append(" " + formatDate(myDate) + " to " + formatDate(new Date()));
                        }
                            function formatDate(date) {
                            var d = new Date(date),
                                month = '' + (d.getMonth() + 1),
                                day = '' + d.getDate(),
                                year = d.getFullYear();

                            if (month.length < 2)
                                month = '0' + month;
                            if (day.length < 2)
                                day = '0' + day;

                            return [month, day, year].join('/');
                        }
        function reloadWithParams() {
            var startDateValue = $('#fromdate').val();
            var endDateValue = $('#todate').val();
                if (startDateValue == '' || endDateValue == '') {
                alert("Please select date range first!");
            return;
            }
            if ($.datepicker.parseDate("mm/dd/yy", endDateValue) < $.datepicker.parseDate("mm/dd/yy", startDateValue)) {
                alert("End date must be greater than start date!");
                return;
            }
            setLocation('@Url.RouteUrl("ReturnRequest/SelectItems")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue);
        }
    });
</script>
