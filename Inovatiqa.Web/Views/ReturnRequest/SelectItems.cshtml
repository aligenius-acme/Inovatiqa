                <h4>Choose Reason of Return</h4>
                <hr />
                <label>Reason of Return </label>
                <select class="form-control" id="returnReson-@item.Itemno">
                    @foreach (var reason in Model.ReturnReasons)
                    {
                        <option value="@reason.Key">@reason.Value</option>
                    }
                </select>
                <label>Action </label>
                <select class="form-control" id="returnAction-@item.Itemno">
                    @foreach (var action in Model.ReturnActions)
                    {
                        <option value="@action.Key">@action.Value</option>
                    }

                </select>
                <label>Quantity </label>
                <input type="number" class="form-control" id="modalQuantity-@item.Itemno" max="@item.Quantity" /><br />
                <input type="button" value="ADD" class="btn btn-success" onclick="validate(@item.Itemno) || (window.location.href = '@Url.Action("SelectItems", "ReturnRequest", new { ItemId = item.Itemno, Selected = Model.SelectedItems, SelectedQuantity = Model.SelectedItemsQuantity, SelectedReason = Model.SelectedItemsReturnReason, SelectedAction = Model.SelectedItemsReturnAction})' + '&ItemQuantity=' + $('#modalQuantity-' +@item.Itemno).val() + '&ReturnReason=' + $('#returnReson-' +@item.Itemno).val() + '&ItemAction=' + $('#returnAction-' +@item.Itemno).val())" />

