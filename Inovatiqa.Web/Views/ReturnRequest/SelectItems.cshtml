        @Html.Resource(@<script type="text/javascript">
            function validate(id) {
            const Quantity = $('#modalQuantity-' + id).val();
            if (Quantity == "" || Number(Quantity) < 1) {
                $('#modalQuantity-' + id).addClass("null");
                alert('Please Select Quantity You want to Return');
                    return true;
                }
                return false;
            }
            function handleQuantityChange(id) {
                $('#modalQuantity-' + id).val($('#quantity-' + id).val())
                $('#icon-' + id).removeClass('fa-minus-circle');
                $('#icon-' + id).addClass('fa-plus-circle');
                $('#addBtn-' + id).removeAttr("href");
                $('#addBtn-' + id).attr("href", "#modal-" + id);
                $('#addBtn-' + id).attr("rel", "modal:open")
            }
        </script>, "js")
