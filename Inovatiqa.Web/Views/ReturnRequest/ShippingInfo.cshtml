@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@

<section class="container-fluid orderstatus-area">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="dashboard-area">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="sidebar_menu font_lato">
                                    <h3>Inovatiqa Dashboard</h3>
                                    @await Html.PartialAsync("_DashboardSideBar", "inovatiqa-returns")
                                </div>
                            </div>

                            <div class="col-md-9">
                                <div class="order-deatil-area s submitrequest step-one">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="tabs font_lato">
                                                <ul>
                                                    <li><a href="#" class="previous-check active">Step One</a></li>
                                                    <li><a href="#" class="previous-check active">Step Two</a></li>
                                                    <li><a href="#" class="active">Step Three</a></li>
                                                    <li><a href="#">Step Four</a></li>
                                                    <li><a href="#">Step Five</a></li>

                                                </ul>

                                                <hr>
                                            </div>

                                        </div>

                                        <div class="col-md-12">
                                            <div class="order-content">

                                                <div class="tab-content">
                                                    <div class="return-invoiceitem font_lato">
                                                        <div class="row">
                                                            <div class="col-md-4 col-sm-4">
                                                                <div class="return-invoice-itemnum" style="justify-content: flex-start;">
                                                                    <p style="color: black;">Items: @Model.SelectedItems.Count</p>
                                                                    <p style="color: black;">Product Value $ @Model.SelectedItemsPrice.ToString("0.00")</p>
                                                                </div>
                                                            </div>

                                                            <div class="col-md-12 col-sm-12">
                                                                <h4 style="color: #46760A; margin-top: 5vh;">Shipping & Authorization Preferences</h4>
                                                                <p>Enter your email address to receive a Return Authorization.</p>
                                                            </div>
                                                            <div class="col-md-6 form-group" style="margin-top: 5vh;">
                                                                <p>Enter the number of shipping labels needed (1 shipping label per shipping container)</p>
                                                                <input type="number" min="1" id="shiplbl" required value="1" class="form-control" style="width: 20%; margin-top: 3vh;">
                                                                <p style="margin-top: 3vh;">Provide at least one email address for your Return Authorization.</p>
                                                                <input type="email" id="email1" required class="form-control" style="margin-top: 3vh; width: 70%;">
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="cancel-req-btns font_roboto text-right" style="margin-top: 0px; width: 80%;">
                                                        <a href="/Return/History" class="btn cancel-btn">Cancel Request</a>
                                                        <a onclick="window.location.href = '@Url.ActionLink("Review", "ReturnRequest", new { Items = Model.SelectedItems, Quantities = Model.SelectedItemsQuantity, Reasons = Model.SelectedItemsReturnReason, Actions = Model.SelectedItemsReturnAction, TotalPrice = Model.SelectedItemsPrice })' + '&ShippingLabel=' + $('#shiplbl').val() + '&Email1=' + $('#email1').val() + '&Email2=' + $('#email2').val()" class="btn continue-btn" data-toggle="modal" data-target="#step-returnpopup" data-backdrop="false">Continue</a>
                                                    </div>
                                                    <div class="tabs font_lato">
                                                        <hr>
                                                    </div>
                                                    <div>
                                                        <p></p>
                                                    </div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
</section>