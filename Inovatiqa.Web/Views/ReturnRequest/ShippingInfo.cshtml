    <div class="page account-page return-request-list-page from-panel">
        <div class="page-title panel-heading">
            <h1>Return requests</h1>
        </div>

        <div style="text-align:right;float:right;">
            <input type="button" value="Cancel" class="btn btn-primary" style="margin-right:0;" onclick="window.location.href='/returnrequest/history'">

            <button class="btn btn_green" style="margin-right:0;" onclick="window.location.href = '@Url.ActionLink("Review", "ReturnRequest", new { Items = Model.SelectedItems, Quantities = Model.SelectedItemsQuantity, Reasons = Model.SelectedItemsReturnReason, Actions = Model.SelectedItemsReturnAction, TotalPrice = Model.SelectedItemsPrice })' + '&ShippingLabel=' + $('#shiplbl').val() + '&Email1=' + $('#email1').val() + '&Email2=' + $('#email2').val()">Continue to Next Step</button>
