                            </tr>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

    <div style="display: flex; flex-direction: column; margin-right: 70%;">
        <p>Enter the number of shipping labels needed (1 shipping label per shipping container)</p>
        <input type="number" class="form-control" name="name" min="1" required id="shiplbl"/>
        <p>Provide at least one email address for your Return Authorization.</p>
        <input class="form-control" type="email" id="email1" required />
        <input class="form-control" style="margin-top: 10px;" type="email" id="email2"/>
    </div>
