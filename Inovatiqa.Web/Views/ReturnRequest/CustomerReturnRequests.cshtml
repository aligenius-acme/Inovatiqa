    <div class="page account-page return-request-list-page from-panel">
        <div class="page-title panel-heading">
            <h1>Return requests</h1>
        </div>
        <div class="page-body">
            <div class="pull-right">
                <a type="button" class="btn btn_green" href="@Url.RouteUrl("CreateReturnRequest", new {controller="ReturnRequest", returnView = "true" })">Create New Return Request</a>
            </div>
            <br />
            <div>
                <h3 class="list-header-orange">
                    Submitted Return Requests
                </h3>
                <h6>
                    All submitted return requests are listed below. Specific items can be clicked on to view credit details, or a return request can be expanded for additional information.
                </h6>
            </div>
            <br />
            <div class="order-list">
                <div id="filter-bar">
                    <label for="viewreturns" class="header-component">View</label>
                    <select id="viewreturns" name="viewreturns" class="form-control header-component">
                        <option value="-1"> All Returns</option>
                        <option value="20"> Closed Returns</option>
                        <option value="O"> Open Returns</option>
                    </select>
                    <label for="searchbox" class="header-component">Find</label>
                    <input type="text" id="searchbox" value="" class="form-control header-component">
                    <label for="searchbox" class="header-component">in</label>
                    <select name="filter" id="searchFilterType" class="form-control header-component">
                        <option value="0" selected="selected">PO</option>
                        <option value="1">Order #</option>
                        <option value="2">Return #</option>
                        <option value="3">Item #</option>
                        <option value="4">Description</option>
                        <option value="5">Manufacturer</option>
                        <option value="6">Mfr #</option>
                    </select>
                    <label for="fromdate" class="header-component">From</label>
                    <input type="text" id="fromdate" value="" readonly="readonly" class="form-control date-picker header-component">
                    <label for="todate" class="header-component">To</label>
                    <input type="text" id="todate" value="" readonly="readonly" class="form-control date-picker header-component">
                    <a type="button" id="customer-returns-filter" title="Filters records for the last 35 days" href="#" class="btn btn-primary" onclick="FilterReturnRequests(); return false;">Find</a>
                    <a type="button" id="customer-returns-clear" href="#" class="btn btn-primary" onclick="ClearFilterReturnRequests(); return false;">Clear</a>
                    <label for="sort" class="header-component">Sort By</label>
                    <select id="sort" name="sort" class="form-control header-component">
                        <option value="false"> Return #</option>
                        <option value="true"> Date Submitted</option>
                    </select>
                </div>
                <br />
                @{
                    if (Model.Items != null && Model.Items.Count > 0)
                    {
                        foreach (var item in Model.Items)
                        {
                            <div class="content-component">
                                            <div class="main-header" onclick="handleExpanssion(this)">
                                                <div class="main">
                                                    @*<input type="button" class="collapsible" value="+" style="border-radius: 100px; border: none;">@

                                                    <div style="margin-left:5px;">
                                                        <i id="expandBtn" class="fa fa-plus-circle pointer"></i>
                                                    </div>
                                                    <div class="return-status" style="color:#999;">@item.ReturnRequestStatus&nbsp;Return&nbsp;#@item.Id</div>
                                                    <div>@item.ReturnRequestStatus</div>
                                                    <div>Submitted on @item.CreatedOn.ToString("MMM dd, yyyy")</div>
                                                    <div><span>Total Pending Credit&nbsp;</span><b class="moneyGreen">@item.PendingCredit</b></div>
                                                </div>
                                                <div style="background-color: #FFF; display: none; overflow: hidden; ">
                                                    <div style="display: flex; justify-content: space-between;">
                                                        <div>
                                                            <p style="font-weight: bold;">Returned From</p>
                                                            <p>@item.BillingAddress.CompanyName</p>
                                                            <p>@item.BillingAddress.AddressLine</p>
                                                            <p>@item.BillingAddress.Country, @item.BillingAddress.ZipCode</p>
                                                        </div>
                                                        <div>
                                                            <table class="tblSimple highlight-body">
                                                                <tr>
                                                                    <td style="width: 100%;">Total Product Credit </td>
                                                                    <td style="color: #393;"> @item.TotalProductCredit</td>
                                                                </tr>
                                                                <tr>
                                                                    <td>Freight </td>
                                                                    <td style="color: #393;"> @item.Freight</td>
                                                                </tr>
                                                                <tr>
                                                                    <td>Total Pending Credit </td>
                                                                    <td style="color: #393;"> @item.PendingCredit</td>
                                                                </tr>

                                                            </table>
                                                        </div>
                                                    </div>

                                                </div>

                                            </div>
                                <div class="component-body">
                                    <table class="tblSimple highlight-body">
                                        <thead>
                                            <tr>
                                                <th>Item #</th>
                                                <th>Description</th>
                                                <th>Order #</th>
                                                <th>PO</th>
                                                <th>Mfr</th>
                                                <th>Mfr #</th>
                                                <th align="center">UOM</th>
                                                <th class="alignRight">Qty</th>
                                                <th class="alignRight">Credit</th>
                                            </tr>
                                        </thead>
                                        <tbody class="cursor-pointer" title="Click to View Detail">
                                            @{
                                                <tr>
                                                    <td>
                                                        @item.ProductId
                                                    </td>
                                                    <td>
                                                        @item.ProductName
                                                    </td>
                                                    <td>@item.OrderId</td>
                                                    <td>@item.PoNumber</td>
                                                    <td>
                                                        @item.ProductManufacturers.FirstOrDefault().Name
                                                    </td>
                                                    <td>@item.ManufacturerPartNumber</td>
                                                    <td align="center">@item.AttributeInfo</td>
                                                    <td class="alignRight">@item.Quantity</td>
                                                    <td class="alignRight">
                                                        <span class="moneyGreen">@item.PendingCredit</span>
                                                    </td>
                                                </tr>
                                                <tr class="trExtra">
                                                    <td></td>
                                                    <td colspan="9"><span style="color:grey;">Reason: @item.ReturnReason</span></td>
                                                </tr>
                                            }

                                        </tbody>
                                    </table>
                                </div>

                            </div>
                        }
                    }
                    else
                    {
                        <div class="content-component" style="margin-top:10px;">
                            <div class="component-body">
                                <span class="noresults">Search returned no Returned Items.</span>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
    @Html.Resource(@<script type="text/javascript">
        $(document).ready(function () {
            searchParams = new URLSearchParams(window.location.search);
            if (searchParams.has('returnStatusId'))
                $('#viewreturns').val(searchParams.get('returnStatusId'));
            if (searchParams.has('returnRequestFindByKey'))
                $('#searchFilterType').val(searchParams.get('returnRequestFindByKey'));
            if (searchParams.has('returnRequestFindByKeyValue'))
                $('#searchbox').val(searchParams.get('returnRequestFindByKeyValue'));
            if (searchParams.has('startDateValue'))
                $('#fromdate').val(searchParams.get('startDateValue'));
            if (searchParams.has('endDateValue'))
                $('#todate').val(searchParams.get('endDateValue'));
            if (searchParams.has('orderByDate'))
                $('#sort').val(searchParams.get('orderByDate'));

            $('#customer-returns-filter').tipsy();

            $("#newSearchPlace").html($(".dataTables_filter"));
            $('#returns_filter').find('input').css({ "font-weight": "100" })

            $('#fromdate').datepicker({
                minDate: '-35D',
                maxDate: '+0',
            }).datepicker("setDate", -35);

            $('#todate').datepicker({
                minDate: '-35D',
                maxDate: '+0',
            }).datepicker("setDate", new Date());
            $('.ui-datepicker').css('font-size', '11px');

            $("#customer-returns-filter").click(function () {
                var startDateValue = $("#fromDate").val();
                var endDateValue = $("#toDate").val();

                if (startDateValue == '' || endDateValue == '') {
                    alert("Please select date range first!");
                    return;
                }

                if ($.datepicker.parseDate("mm/dd/yy", endDateValue) < $.datepicker.parseDate("mm/dd/yy", startDateValue)) {
                    alert("End date must be greater than start date!");
                    return;
                }

                setLocation('@Url.RouteUrl("CustomerReturnRequests")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue);
            });

            $("#customer-returns-clear").click(function () {
                setLocation('@Url.RouteUrl("CustomerReturnRequests")');
            });
        });
        function FilterReturnRequests() {
            var returnStatusId = $('#viewreturns').val();
            var returnRequestFindByKey = $('#searchFilterType').val();
            var returnRequestFindByKeyValue = $('#searchbox').val();
            var startDateValue = $('#fromdate').val();
            var endDateValue = $('#todate').val();
            var orderByDate = $('#sort').val();

            var query = "?";
            if (orderByDate.trim() != "true")
                query += "orderByDate=" + orderByDate.trim();
            if (startDateValue.trim() != "")
                query += "&startDateValue=" + startDateValue.trim();
            if (endDateValue.trim() != "")
                query += "&endDateValue=" + endDateValue.trim();
            if (returnStatusId.trim() != "-1")
                query += "&returnStatusId=" + returnStatusId.trim();
            if (returnRequestFindByKeyValue.trim() != "") {
                query += "&returnRequestFindByKey=" + returnRequestFindByKey.trim();
                query += "&returnRequestFindByKeyValue=" + returnRequestFindByKeyValue.trim();
            }

            window.location.href = "/returnrequest/history" + query;
        }
        function ClearFilterReturnRequests() {
            window.location.href = "/returnrequest/history";
        }

        function handleExpanssion(elem) {
            // change plus button into minus and vice versa
            const btn = elem.childNodes[1].childNodes[1].childNodes[1];
            $(btn).toggleClass("fa-plus-circle fa-minus-circle");

            const div = elem.childNodes[3];
            $(div).slideToggle("slow", function () {/* Success */ })
        }
    </script>, "js")
*@

