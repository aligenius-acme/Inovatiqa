<section class="container-fluid orderstatus-area">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-12">
                    <div class="dashboard-area">
                        <div class="row">
                            <div class="col-md-3">
                                <div class="sidebar_menu font_lato">
                                    <h3>Inovatiqa Dashboard</h3>
                                    @await Html.PartialAsync("_DashboardSideBar", "inovatiqa-returns")
                                </div>
                            </div>

                            <div class="col-md-9">
                                <div class="order-deatil-area s submitrequest">
                                    <div class="row">
                                        <div class="col-md-12">
                                            <div class="tabs font_lato">
                                                <ul>
                                                    <li><a href="#" class="active">Returns</a></li>
                                                    <li><a hred="#">View Submitted Return Request</a></li>
                                                    <li><a href="@Url.RouteUrl("CreateReturnRequest", new {controller="ReturnRequest", returnView = "true" })" class="new-return">Create Return Request</a></li>

                                                </ul>

                                                <hr>
                                            </div>

                                        </div>

                                        <div class="col-md-12">
                                            <div class="order-content">

                                                <div class="tab-content" style="border: none !important;">
                                                    <div class="contact-manager text-right font_roboto">
                                                        <a href="#" class="btn conatct-btnpopup" data-toggle="modal" data-target="#contact-mform">Contact Your Account Manager</a>
                                                    </div>

                                                    <div class="form-group">
                                                        <select class="form-control" style="width: 20%; margin-bottom: 6vh;" id="viewreturns" name="viewreturns">
                                                            <option value="-1">View All Returns</option>
                                                            <option value="20">View Closed Returns</option>
                                                            <option value="0">View Open Returns</option>
                                                        </select>
                                                    </div>

                                                    <div class="order-find-area">
                                                        <div class="find-fields font_lato">
                                                            <div class="form-group">
                                                                <label>Find</label>
                                                                <input type="text" class="form-control" id="searchbox">
                                                            </div>

                                                            @*<div class="form-group">
                                                                <label>In</label>
                                                                <select disabled class="form-control" name="filter" id="searchFilterType">
                                                                    <option value="-1">All Fields</option>
                                                                    <option value="1">Order #</option>
                                                                    <option value="2">Item #</option>
                                                                    <option value="3">Description</option>
                                                                </select>
                                                            </div>*@
                                                        </div>

                                                        <div class="date-fileds font_lato">
                                                            <div class="form-group">
                                                                <label>From</label>
                                                                <input type="text" id="fromdate" value="@DateTime.Today.AddDays(-35).ToString("MM/dd/yyyy")" class="form-control date-picker" placeholder="7/2/2021">
                                                            
                                                            </div>

                                                            <div class="form-group">
                                                                <label>To</label>
                                                                <input type="text" id="todate" value="@DateTime.Today.ToString("MM/dd/yyyy")" class="form-control date-picker" placeholder="7/2/2021">

                                                            </div>

                                                            <div class="find-btn font_roboto">
                                                                 <input type="submit" id="customer-returns-filter" value="Find" class="btn btn-signin" />
                                                                <input type="submit" id="customer-returns-clear" value="Clear" class="btn btn-signin" />
                                                             </div>
                                                        </div>

                                                        <div class="print-fileds font_lato">
                                                            <div class="form-group">
                                                                <label>Sort By</label>
                                                                <select class="form-control" id="sort" name="sort">
                                                                    <option value="false"> Return #</option>
                                                                    <option value="true"> Date Submitted</option>
                                                                </select>
                                                            </div>

                                                            <div class="print-button font_roboto">
                                                                <a href="#" class="btn btn-print"><img src="~/images/UIComponents/print-btn-img.svg">Print</a>
                                                            </div>
                                                        </div>
                                                    </div>

                                                    <div class="items-table-area table-responsive font_roboto">
                                                        <table class="table border-collapse mb0" id="myTable">
                                                            <thead>
                                                                <tr>
                                                                    <th>Item Number</th>
                                                                    <th>Description</th>
                                                                    <th>Order Number</th>
                                                                    <th>UOM</th>
                                                                    <th>Quantity</th>
                                                                    <th>Credit Total</th>
                                                                </tr>
                                                            </thead>

                                                            <tbody>
                                                                @if (Model.Items != null && Model.Items.Count > 0)
                                                                {
                                                                    foreach (var item in Model.Items)
                                                                    {
                                                                        <tr>
                                                                            <td>
                                                                                <p class="num-blue des-padding">@item.ProductId</p>
                                                                            </td>

                                                                            <td style="width: 30%;">
                                                                                <a style="color:unset;" href="@Url.RouteUrl("Product", new { SeName = item.ProductSeName })"><p class="des-padding">@item.ProductName</p></a>
                                                                                <p class="des-fontsize des-blue">Manufacturer / Manufacturer #</p>
                                                                                <p class="des-fontsize">@item.ProductManufacturers.FirstOrDefault().Name / @item.ManufacturerPartNumber</p>
                                                                            </td>

                                                                            <td>
                                                                                <p class="num-green des-padding">@item.OrderId</p>
                                                                            </td>

                                                                            <td>
                                                                                @{
                                                                                    Regex regex = new Regex("UOM: [A-Za-z]{1,4}(/){0,1}[0-9]{1,4}");
                                                                                    Match match = regex.Match(item.AttributeInfo);
                                                                                }
                                                                                <input type="text" size="4" placeholder="@match.Value.Replace("UOM: ", "")" class="eainput-td" disabled />

                                                                            </td>

                                                                            <td>
                                                                                <p class="des-padding">@item.Quantity</p>
                                                                            </td>

                                                                            <td>
                                                                                <p class="des-padding">@item.PendingCredit</p>
                                                                            </td>

                                                                        </tr>
                                                                    }

                                                                }


                                                            </tbody>
                                                        </table>
                                                    </div>

                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>



