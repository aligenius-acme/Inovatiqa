                                                    searchParams = new URLSearchParams(window.location.search);
                                                    if (searchParams.has('returnStatusId'))
                                                        $('#viewreturns').val(searchParams.get('returnStatusId'));
                                                    $('.date-picker').datepicker();
                                                    $('.ui-datepicker').css('font-size', '11px');
                                                    $('#customer-returns-filter').click(function() {
                                                        reloadWithParams();
                                                    });
                                                    $('#customer-returns-clear').click(function() {
                                                        setLocation('@Url.RouteUrl("CustomerReturnRequests")');
                                                    });
                                                    if (searchParams.has('startDateValue') && searchParams.has('endDateValue')) {
                                                        $("#fromdate").val(searchParams.get('startDateValue'));
                                                        $("#todate").val(searchParams.get('endDateValue'));
                                                        $('#pageTitle').append(" " + searchParams.get('startDateValue') + " to " + searchParams.get('endDateValue'));
                                                        $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("StartDate", searchParams.get('startDateValue')));
                                                        $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("EndDate", searchParams.get('endDateValue')));
                                                    }
                                                    else {
                                                        var dateOffset = (24 * 60 * 60 * 1000) * 35;
                                                        var myDate = new Date();
                                                        myDate.setTime(myDate.getTime() - dateOffset);
                                                        $('#pageTitle').append(" " + formatDate(myDate) + " to " + formatDate(new Date()));
                                                    }
                                                        function formatDate(date) {
                                                        var d = new Date(date),
                                                            month = '' + (d.getMonth() + 1),
                                                            day = '' + d.getDate(),
                                                            year = d.getFullYear();

                                                        if (month.length < 2)
                                                            month = '0' + month;
                                                        if (day.length < 2)
                                                            day = '0' + day;

                                                        return [month, day, year].join('/');
                                                    }
                                                    function reloadWithParams() {
                                                        var returnStatusId = Number($('#viewreturns').val());
                                                        var returnRequestFindByKey = $('#searchFilterType').val();
                                                        var returnRequestFindByKeyValue = $('#searchbox').val();
                                                        var startDateValue = $('#fromdate').val();
                                                        var endDateValue = $('#todate').val();
                                                        var orderByDate = $('#sort').val();
                                                        if (startDateValue == '' || endDateValue == '') {
                                                            alert("Please select date range first!");
                                                        return;
                                                        }
                                                        if ($.datepicker.parseDate("mm/dd/yy", endDateValue) < $.datepicker.parseDate("mm/dd/yy", startDateValue)) {
                                                            alert("End date must be greater than start date!");
                                                            return;
                                                        }
                                                        //if (searchParams.has('returnStatusId')) {
                                                        //    returnStatusId = searchParams.get('returnStatusId');
                                                        //}
                                                        setLocation('@Url.RouteUrl("CustomerReturnRequests")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue + '&returnStatusId=' + returnStatusId + '&orderByDate=' + orderByDate + '&returnRequestFindByKey=' + returnRequestFindByKey + '&returnRequestFindByKeyValue=' + returnRequestFindByKeyValue);
                                                    }
                                                    });
    </Script>, "js")