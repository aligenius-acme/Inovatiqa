@model ManufacturerModel
@using Inovatiqa.Core
@{
    Layout = "~/Views/Shared/_Root.cshtml";
    //Layout = "_ColumnsOne";
    //    Layout = "_ColumnsTwo";
}
@{
    ViewBag.Title = !string.IsNullOrEmpty(Model.MetaTitle) ? Model.MetaTitle : Model.Name;
}
@*
    <style>
        ul {
            list-style: none;
        }
    </style>*@
@section additionalMeta {
    <meta name="title" content="@ViewBag.Title" />
    <meta name="keywords" content="@Model.MetaKeywords" />
    <meta name="description" content="@Model.MetaDescription" />
}
<img src="~/images/UIComponents/bg6.png" class="full_width_img" />

<section class="container-fluid">
    <div class="row">
        <div class="container">
            <div class="row flex_col m_t_20 m_b_70">
                <div class="col-md-10 brad_crump">
                    <a href="@Url.RouteUrl("Homepage")">Homepage</a>
                    <span>/</span>
                    <span itemprop="name">@Model.Name</span>
                </div>
            </div>
        </div>
    </div>
</section>

<section class="container-fluid" style="background: rgba(241, 243, 246, 0.45);">
    <div class="row">
        <div class="container">
            <div class="row flex_col m_t_10 m_b_50">
                <div class="col-md-12 title_text font_lato">
                    <div class="row flex_col align_center">
                        <div class="col-md-12 col-sm-12 col-xs-12">
                            <h2>
                                <strong>@Html.Raw(Model.Name)</strong>
                            </h2>
                        </div>
                    </div>
                        <div class="row flex_col m_t_70 ">
                            <div class="col-md-3 col-xs-12">
                                <div class="list_box rating_sec m_t_30 p30">
                                    <div class="price_section">
                                        <h4>Price</h4>
                                        <div class="row flex_col align_center">
                                            <div class="col-xs-6 min_max_sec">
                                                <label>Min</label>
                                                <input type="number" class="form-control" maxlength="5" placeholder="0" id="priceMin" value="@Model.MinPrice" />
                                            </div>
                                            <div class="col-xs-6">
                                                <label>Max</label>
                                                <input type="number" class="form-control" maxlength="5" placeholder="000" id="priceMax" value="@Model.MaxPrice" />
                                            </div>
                                        </div>
                                    </div>

                                    <div class="button_section m_t_30">
                                        <input type="submit" value="Apply" class="btn btn-primary" onclick="apply_price_filter()" />
                                        <a href="javascript:void(0)" onclick="reset_price_filter()" class="btn_reset">Reset</a>
                                    </div>
                                </div>
                            </div>
                        <div class="col-md-9 col-xs-12">
                            <div class="row">
                                <div class="col-md-12 first_a">
                                    <a href='@Url.RouteUrl("CompareProducts")' class="compare pointer"><img src="~/images/UIComponents/ic-actions-check2.png" width="20" height="20" /> <span class="comp-button"> Compare Selected Items ( @Model.Products.Where(product => product.IsInCompareList).ToList().Count ) </span></a>
                                    <a onclick="AjaxCart.clearcomparelistwithoutredirect('@Url.RouteUrl("ClearCompareListWithoutRedirect")');return false;" style="cursor: pointer;"><img src="~/images/UIComponents/ic-actions-remove.svg" /> Clear list</a>
                                </div>
                                @if (Model.Products.Count > 0)
                                {
                                    @foreach (var product in Model.Products)
                                    {
                                        @await Html.PartialAsync("_CategoryProductBox", product)
                                    }
                                }
                                @if (Model.Products.ToList().Count == 0)
                                {
                                    <div class="alert alert-info mt16 ml21" style="margin-top:50px;" role="alert">
                                        No products found. Please search something more generic.
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>


