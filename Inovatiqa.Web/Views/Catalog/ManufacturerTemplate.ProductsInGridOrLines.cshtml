<section class="container-fluid" style="background-color: #f9fafb;">
    @{
        var pager = Html.Pager(Model.PagingFilteringContext, Context.Request).QueryParam("pagenumber");
    }
    <div class="row">
        <div class="container p_t_30 p_b_30">
            <div class="row flex_col align_center">
                <div class="col-sm-6 col-xs-5">
                    <div class="product_number_box">
                        <span>@pager.model.TotalItems</span> Products
                    </div>
                </div>
                <div class="col-sm-6  col-xs-7">
                    <div class="pagination">
                        @if (!pager.IsEmpty())
                        {
                            <span>Page</span>
                            @pager
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    function apply_price_filter() {
        const minPrice = parseInt($('#priceMin').val());
        const maxPrice = parseInt($('#priceMax').val());
        const { href } = window.location;
        if (minPrice > maxPrice) {
            alert('Min price must be less than Max price');
        }
        else if (minPrice > 0 && maxPrice > 0) {
            if (href.match(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i) && href.match(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = href.replace(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i, `?minPrice=${minPrice}`).replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, `&maxPrice=${maxPrice}`);
            }
            else if (href.match(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i)) {
                window.location.href = window.location.href.replace(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i, "") + `?minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;
            }
            else if (href.match(/(\?){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = window.location.href.replace(/(\?){0,1}(\?){0,1}maxPrice=[0-9]+/i, "") + `?minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;

            }
            else {
                window.location.href += `?minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;
            }
        }
        else if (minPrice > 0) {
            if (href.match(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i)) {
                window.location.href = href.replace(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i, `?/minPrice=${minPrice}`).replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, "");
            }
            else {
                window.location.href = window.location.href.replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, "") + `?minPrice=${minPrice}`;
            }
        }
        else if (maxPrice > 0) {
            if (href.match(/(\?){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "").replace(/(\?){0,1}(\?){0,1}maxPrice=[0-9]+/i, `?maxPrice=${maxPrice}`);
            }
            else {
                window.location.href = window.location.href.replace(/(\?){0,1}(\?){0,1}minprice=[0-9]+/i, "") + `?maxPrice=${maxPrice}`;
            }
        }
    }
    function reset_price_filter() {
        window.location.href = window.location.href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "").replace(/(&){0,1}(\?){0,1}maxprice=[0-9]+/i, "");
    }
</script>
