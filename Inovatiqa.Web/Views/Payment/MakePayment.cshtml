                                        <div class="form-group">
                                            <form action="/MakingPayment" method="post">
                                                <select asp-for="StoredCardId" asp-items="Model.StoredCards" class="square-input form-control"></select>
                                                <input type="hidden" name="invoiceIdsAmounts" value="@Model.invoiceIdsAmounts" />
                                                <input type="hidden" name="AmountToPay" value="@Model.AmountToPay" />
                                                <input type="hidden" name="OrderId" id="OrderId" value="@Model.OrderIds" />
                                                <input type="hidden" name="InvoiceIds" id="InvoiceIds" value="@Model.InvoiceIds" />
                                                <button type="submit" hidden id="btnsubmit"></button>
                                            </form>
                                        </div>
                                    </div>
                                }
                                <div class="col-md-3 col-sm-3 col-xs-12">
                                    <div class="form-group">
                                        <label class="">Add New Method</label>
                                    </div>
                                </div>
                                <div class="col-md-9 col-sm-9 col-xs-12">
                                    <div class="form-group">
                                       <select id="paymentmethoddropdown" onchange="paymentmethodchanged();" class="form-control">
                                            <option value="0">Add a payment method</option>
                                            <option value="1">Bank Account</option>
                                            <option value="2">Credit Card</option>
                                        </select>
                                    </div>
                                </div>
                                <div id="ACHBankPayment" hidden>
                                    <form id="payment-form">
                                        <div class="col-md-3 col-sm-3 col-xs-12"></div>
                                        <div class="col-md-9 col-sm-9 col-xs-12">
                                            <span id="payment-flow-message" class="alert"></span>
                                            <span id="ach-message" class="alert"></span>
                                        </div>
                                        <div class="col-md-3 col-sm-3 col-xs-12">
                                            <div class="form-group" style="line-height:55px;">
                                                <label for="ach-account-holder-name">First Name</label>
                                                <label for="ach-account-holder-name">Last Name</label>
                                            </div>
                                        </div>
                                        <div class="col-md-9 col-sm-9 col-xs-12">
                                            <div class="form-group">
                                                <fieldset class="buyer-inputs">
                                                    <input
                                                     type="text"
                                                     class="form-control"
                                                     autocomplete="given-name"
                                                     aria-required="true"
                                                     aria-label="First Name"
                                                     required="required"
                                                     value="@Model.BillingFirstName" 
                                                     placeholder="Given Name"
                                                     name="givenName"
                                                     spellcheck="false"
                                                   />
                                                   <br />
                                                   <input
                                                     type="text"
                                                     class="form-control"
                                                     autocomplete="family-name"
                                                     aria-required="true"
                                                     aria-label="Last Name"
                                                     required="required"
                                                     value="@Model.BillingLastName"
                                                     placeholder="Family Name"
                                                     name="familyName"
                                                     spellcheck="false"
                                                   />
                                                </fieldset>
                                            </div>
                                        </div>
                                        <div class="col-md-3 col-sm-3 col-xs-12"></div>
                                        <div class="col-md-9 col-sm-9 col-xs-12">
                                            <div class="form-group font_roboto">
                                                <button type="button" class="btn btn-signin" id="ach-button">Pay with Bank Account</button>
                                            </div>
                                        </div>
                                    
                                     </form> 

                                    @*<form id="fast-checkout">
                                        <div class="col-md-3 col-sm-3 col-xs-12"></div>
                                        <div class="col-md-9 col-sm-9 col-xs-12">
                                            <span id="payment-flow-message" class="alert"></span>
                                            <span id="ach-message" class="alert"></span>
                                        </div>
                                        <div id="ach-wrapper">
                                            <div class="col-md-3 col-sm-3 col-xs-12">
                                                <div class="form-group">
                                                    <label for="ach-account-holder-name">Full Name</label>
