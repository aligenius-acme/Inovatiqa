                                            </div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                   <input id="ach-account-holder-name" type="text" placeholder="Your Full Name" value="@Model.BillingFirstName @Model.BillingLastName" class="form-control" name="ach-account-holder-name" autocomplete="name" style="border-radius: 0px;"/>
                                                </div>
                                            </div>
                                            <div class="col-md-3 col-sm-3 col-xs-12"></div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group font_roboto">
                                                   <button id="ach-button" type="button" class="btn btn-signin">Pay Using Bank</button>
                                                </div>
                                            </div>
                                        </div>
                                    </form>
                                </div>
                                <div id="Carddiv" style="display: none;">
                                    <form id="co-payment-info-form" method="post">
                                        <input type="hidden" asp-for="CardNonce" />
                                        <input type="hidden" asp-for="Errors" />
                                        <input type="hidden" asp-for="Token" />
