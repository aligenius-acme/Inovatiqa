                                    </form>
                                    <div id="square-card-details">
                                        <div>
                                            <div class="col-md-3 col-sm-3 col-xs-12">
                                                <div class="form-group">
                                                    <label for="square-card-number">Card number</label>
                                                </div>
                                            </div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                    <div id="square-card-number" style="width:165px;"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="col-md-3 col-sm-3 col-xs-12">
                                                <div class="form-group">
                                                    <label for="square-card-number">Expiration Date</label>
                                                </div>
                                            </div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                    <div id="square-expiration-date"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="col-md-3 col-sm-3 col-xs-12">
                                                <div class="form-group">
                                                    <label for="square-card-number">CVV Code</label>
                                                </div>
                                            </div>
                                             <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                    <div id="square-cvv" style="width:60px;"></div>
                                                </div>
                                            </div>
                                        </div>
                                        <div>
                                            <div class="col-md-3 col-sm-3 col-xs-12">
                                                <div class="form-group">
                                                    <label asp-for="PostalCode">Postal code</label>
                                                </div>
                                            </div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                    <div id="square-postal-code"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    <div id="payment_info" class="tab-section">
                                        <div id="checkout-step-payment-info" class="step a-item">
                                            @*<form id="co-payment-info-form">
                                            </form>*@
                                            @Html.Resource(@<script type="text/javascript">
                                                                                        PaymentInfoSecond.init('#co-payment-info-form', '@(InovatiqaDefaults.StoreUrl)Payment/SavePaymentInfo/');
                                                                                    </script>, "js")
                                            <div class="buttons" id="payment-info-buttons-container">
                                                <div class="col-md-8 col-sm-8 col-xs-12">
                                                <div class="form-group font_lato">
                                                    <a class="btn primary edit font_roboto" style="margin-top: 0px;" onclick="Cancelbtn();">Cancel</a>
                                                </div>
                                                </div>
                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                    <div class="form-group font_lato">
                                                        <input type="button" class="btn btn-signin payment-info-next-step-button" value="Save Card" />
                                                    </div>
