                                            </div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group">
                                                   <input id="ach-account-holder-name" type="text" placeholder="Your Full Name" value="@Model.BillingFirstName @Model.BillingLastName" class="form-control" name="ach-account-holder-name" autocomplete="name" style="border-radius: 0px;"/>
                                                </div>
                                            </div>
                                            <div class="col-md-3 col-sm-3 col-xs-12"></div>
                                            <div class="col-md-9 col-sm-9 col-xs-12">
                                                <div class="form-group font_roboto">
                                                   <button id="ach-button" type="button" class="btn btn-signin">Pay Using Bank</button>
                                                </div>
                                            </div>
                                        </div>
                                    </form>*@
                                </div>
                            </div>
                            <div id="Carddiv" hidden style="height:50px;">
                                <form id="co-payment-info-form" method="post">
                                    <input type="hidden" asp-for="CardNonce" />
                                    <input type="hidden" asp-for="Errors" />
                                    <input type="hidden" asp-for="Token" />
                                </form>
                                <div id="square-card-details" style="height:50px;">
                                    <div id="card-container"></div>
                                    <div id="payment_info" class="tab-section">
                                        <div id="checkout-step-payment-info" class="step a-item">
                                            @Html.Resource(@<script type="text/javascript">
                                                                                                                            PaymentInfoSecond.init('#co-payment-info-form', '@(InovatiqaDefaults.StoreUrl)Payment/SavePaymentInfo/');
                                                                                                                        </script>, "js")
                                            <div class="buttons" id="payment-info-buttons-container">
                                                <div class="col-md-8 col-sm-8 col-xs-12">
                                                    <div class="form-group font_lato">
                                                        <a class="btn primary edit font_roboto" style="margin-top: 0px;" onclick="Cancelbtn();">Cancel</a>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 col-sm-4 col-xs-12">
                                                    <div class="form-group font_lato">
                                                        <input type="button" style="max-width:150%;" id="card-button" class="btn btn-signin payment-info-next-step-button" value="Save Card" />
                                                    </div>
                                                </div>
                                                <br />
                                                <span class="please-wait" id="payment-info-please-wait" style="display: none;">Loading next step...</span>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>

    function paymentmethodchanged() {

        displayAjaxLoading(true);
        var dropdownvalue = document.getElementById("paymentmethoddropdown").value;
        if (dropdownvalue == 1) {
            $("#ACHBankPayment").show();
            $("#Carddiv").hide();
            displayAjaxLoading(false);
        }
        else if (dropdownvalue == 2) {
            $("#Carddiv").show();
            $("#ACHBankPayment").hide();
            $("#Topbardiv").hide();
            displayAjaxLoading(false);

        }
        else {
            $("#Carddiv").hide();
            $("#ACHBankPayment").hide();
            $("#Topbardiv").show();
            displayAjaxLoading(false);
        }
    }

    function Cancelbtn() {

        $("#Carddiv").hide();
        $("#ACHBankPayment").hide();
        $("#Topbardiv").show();

        document.getElementById("paymentmethoddropdown").value = 0;

    }


    function CreatePayment() {
        displayAjaxLoading(true);
        if (document.getElementById("StoredCardId").value != "00000000-0000-0000-0000-000000000000") {
            document.getElementById("btnsubmit").click();
        }
        else {
            alert("Please select a card from the dropdown list.")
        }

    }

    function banksavebtn() {
        $.ajax({
            url: '/Payment/MakeAchPayment',
            cache: false,
            async: false,
            data: {},
            success: function (res) {
                console.log(res);
            },
            error: function (err) {
                console.log(err);
            }
        });
    }

</script>