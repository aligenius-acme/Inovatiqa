                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
<script>

    function paymentmethodchanged() {

        displayAjaxLoading(true);
        var dropdownvalue = document.getElementById("paymentmethoddropdown").value;
        if (dropdownvalue == 1) {
            $("#ACHBankPayment").show();
            $("#Carddiv").hide();
            displayAjaxLoading(false);
        }
        else if (dropdownvalue == 2) {
            $("#Carddiv").show();
            $("#ACHBankPayment").hide();
            $("#Topbardiv").hide();
            displayAjaxLoading(false);

        }
        else {
            $("#Carddiv").hide();
            $("#ACHBankPayment").hide();
            $("#Topbardiv").show();
            displayAjaxLoading(false);
        }
    }

    function Cancelbtn() {

        $("#Carddiv").hide();
        $("#ACHBankPayment").hide();
        $("#Topbardiv").show();

        document.getElementById("paymentmethoddropdown").value = 0;

    }


    function CreatePayment() {
        displayAjaxLoading(true);
        if (document.getElementById("StoredCardId").value != "00000000-0000-0000-0000-000000000000") {
            document.getElementById("btnsubmit").click();
        }
        else {
            alert("Please select a card from the dropdown list.")
        }

    }

    function banksavebtn() {
        $.ajax({
            url: '/Payment/MakeAchPayment',
            cache: false,
            async: false,
            data: {},
            success: function (res) {
                console.log(res);
            },
            error: function (err) {
                console.log(err);
            }
        });
    }

</script>