<style>
    .jqueryPagination {
        display: flex;
        justify-content: space-between;
        margin: 12px;
    }

    .paging_numbers span a {
        margin-right: 5px;
        cursor: pointer;
        color: #636363;
    }

    .paging_numbers span .current {
        color: #000;
    }

    .jqueryPagination p {
        font-family: Lato;
        font-style: normal;
        font-weight: normal;
        font-size: 13.5px;
        letter-spacing: 0.05em;
        color: #636363;
        margin-bottom: unset;
    }
</style>


@await Component.InvokeAsync("DashboardBlueBand")
@*@await Html.PartialAsync("_DashboardBlueBand")*@
<section class="container-fluid deshboard_section k">
    <div class="row">
        <div class="container">
            <div class="row">
                <div class="col-md-3">
                    <div class="sidebar_menu font_lato">
                        <h3>Inovatiqa Dashboard</h3>
                        @await Html.PartialAsync("_DashboardSideBar", "payment-portal")
                    </div>
                </div>
                <div class="col-md-9">
                    <div class="payment_portal_top">
                        <div class="payment_type_list">
                            <ul>
                                <li><a href="@Url.RouteUrl("PaymentPortal")">Home</a></li>
                                <li><a href="@Url.RouteUrl("OpenInvoices")">Open Invoices</a></li>
                                <li><a href="@Url.RouteUrl("UnappliedCash")">Unapplied Cash</a></li>
                                <li><a href="@Url.RouteUrl("PaidInvoices")" class="active">Paid Invoices</a></li>
                            </ul>
                        </div>
                        <hr class="line">
                        <h2>Paid Invoices</h2>
                        <div class="details_off_amount open_invoices">
                            <div class="boxss">
                                <h4>Paid Invoices</h4>
                                <p>This is a list of invoices that were Paid in Full within the last 60 days.</p>
                                <p>For Accounts Receivable, please contact the phone number on your invoice.</p>
                            </div>
                            <div class="boxss">
                                <h4>Billing Account</h4>
                                <p>@Model.BillingAddress.Id <br> @Model.BillingAddress.FirstName @Model.BillingAddress.LastName</p>
                            </div>
                            <div class="boxss">
                                <h4>Billing Address</h4>
                                <p>@Model.BillingAddress.Address1 <br> @Model.BillingAddress.City, @Model.BillingAddress.StateProvinceName @Model.BillingAddress.ZipPostalCode</p>
                            </div>
                        </div>
                    </div>
                    <div class="payment_portal_bottom font_roboto table-responsive payment_portal_bottom_open_invoice" style="margin-top: 7vh;">
                        <table class="table border-collapse mb0" id="paidInvoicesTable">

                            <thead>
                                <tr>
                                    <th>Invoice Number</th>
                                    <th>Description</th>
                                    <th>Invoice Date</th>
                                    <th>Due Date</th>
                                    <th>Payment Date</th>
                                    <th>Order Number</th>
                                    <th>Purchase Order Number</th>
                                    <th>Original Amount</th>
                                </tr>
                            </thead>
                            @if (Model != null)
                            {
                                @if (Model.PaymentShipmentListModel.Count > 0)
                                {
                                    @foreach (var item in Model.PaymentShipmentListModel)
                                    {
                                        @if (item.PaymentStatusId == (int)PaymentStatus.Paid)
                                        {
                                            <tr>
                                                <td>@item.Id</td>
                                                <td>Invoice</td>
                                                <td>@item.CreatedDate</td>
                                                <td>@(item.InvoiceDueDate.HasValue ? item.InvoiceDueDate.ToString().Split(" ")[0] : "")</td>
                                                <td>@(item.InvoicePayedDate.HasValue ? item.InvoicePayedDate.ToString().Split(" ")[0] : "")</td>
                                                <td>@item.CustomOrderNumber</td>
                                                <td>@item.PurchaseOrderNumber</td>
                                                <td>@item.TotalShipmentAmount</td>
                                            </tr>
                                        }
                                    }
                                }
                            }
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
    $(document).ready(function () {
        const dt = $('#paidInvoicesTable').DataTable({
            "language": {
                "info": '<div class="tpage-num"><p>Showing _START_ to _END_ of _TOTAL_ Items</p></div>'
            },
            "pageLength": 5,
            "dom": 't<"jqueryPagination"ip>',
            'pagingType': 'numbers'
        });
    });
</script>