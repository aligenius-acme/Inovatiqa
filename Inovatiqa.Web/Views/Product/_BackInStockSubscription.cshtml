@model ProductDetailsModel
@if (Model.DisplayBackInStockSubscription)
{
    <div class="back-in-stock-subscription">
        <input type="button" id="back-in-stock-subscribe-@Model.Id" class="btn btn-default subscribe-button" value="Notify me when available" />
        @Html.Resource(@<script type="text/javascript">
           $(document).ready(function () {
                $("#back-in-stock-subscribe-@Model.Id").on('click', function() {
                    displayPopupContentFromUrl('@Url.RouteUrl("BackInStockSubscribePopup", new { productId = Model.Id })', 'Notify me when available');
                });
            });
        </script>, "js")
    </div>
}