@model ProductDetailsModel
@using Inovatiqa.Database
@using Inovatiqa.Core
@{
    Layout = "_ColumnsOne";
}

@{
    ViewBag.Title = !string.IsNullOrEmpty(Model.MetaTitle) ? Model.MetaTitle : Model.Name;
}
@section additionalMeta {
    <meta name="title" content="@ViewBag.Title" />
    <meta name="keywords" content="@Model.MetaKeywords" />
    <meta name="description" content="@Model.MetaDescription" />
}
<style>
    .purchase-item {
        float: left;
        border: 5px solid #f3f3f3;
        text-align: center;
        padding: 30px 0px 20px 0px;
        width: 100%
    }

        .purchase-item input {
            border-radius: 0px;
        }

        .purchase-item select {
            border-radius: 0px;
        }

    .uom {
        white-space: nowrap;
        width: 73%;
        margin: 1em;
        float: left;
    }

    .btn_large {
        padding: 10px 30px;
        font-size: 1.2em;
        max-width: 13.75em;
    }

    .product-add-button {
        padding: 3%;
    }

        .product-add-button input {
            width: 100%;
            margin: 4px;
        }
</style>
