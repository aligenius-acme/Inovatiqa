<script>
function reloadWithManufacturer(e, id) {
    var href = window.location.href;
    if (href.includes('&pagenumber')) {
        href = href.replace(/&pagenumber=[0-9]+&/, '');
    }
    if ($(e).is(':checked')) {
        window.location.href = href + `&manufectuererFilter=${id}`;
    }
    else {
        window.location.href = href.replace(`&manufectuererFilter=${encodeURI(id)}`, '');
    }
}
</script>
<script>
$('#searchPageNumber').on('change', function() {
    //alert(this.value);

    const href = window.location.href.replace(/&pageSize=[0-9]+/, '');
    window.location.href = href + `&pageSize=${this.value}`;
});
function category_filter(id) {
   // const href = window.location.href.replace(/&catSearchFilter=[0-9]+/,'');
    var href = window.location.href;
    if (href.includes('&pagenumber')) {
        href = href.replace(/&pagenumber=[0-9]+&/, '')
    }
    window.location.href = href + `&catSearchFilter=${id}`;
    
}
function attribute_filter(id) {
    var href = window.location.href;
    if (href.includes('&pagenumber')) {
        href = href.replace(/&pagenumber=[0-9]+&/, '')
    }
    window.location.href = href + `&attSearchFilter=${id}`;
}
function apply_price_filter() {
        const minPrice = parseInt($('#priceMin').val());
        const maxPrice = parseInt($('#priceMax').val());
        var href = window.location.href;
        if (href.includes('&pagenumber')) {
            href = href.replace(/&pagenumber=[0-9]+&/, '');
        }
        if (minPrice > maxPrice) {
            alert('Min price must be less than Max price');
        }
        else if (minPrice > 0 && maxPrice > 0) {
            if (href.match(/(&){0,1}(\?){0,1}minprice=[0-9]+/i) && href.match(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, `&minPrice=${minPrice}`).replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, `&maxPrice=${maxPrice}`);
            }
            else if (href.match(/(&){0,1}(\?){0,1}minprice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "") + `&minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;
            }
            else if (href.match(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, "") + `&minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;

            }
            else {
                window.location.href = href + `&minPrice=${minPrice}` + `&maxPrice=${maxPrice}`;
            }
        }
        else if (minPrice > 0) {
            if (href.match(/(&){0,1}(\?){0,1}minprice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, `&minPrice=${minPrice}`).replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, "");
            }
            else {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, "") + `&minPrice=${minPrice}`;
            }
        }
        else if (maxPrice > 0) {
            if (href.match(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i)) {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "").replace(/(&){0,1}(\?){0,1}maxPrice=[0-9]+/i, `&maxPrice=${maxPrice}`);
            }
            else {
                window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "") + `&maxPrice=${maxPrice}`;
            }
        }
    }
    function reset_price_filter() {
        var href = window.location.href;
        if (href.includes('&pagenumber')) {
            href = href.replace(/&pagenumber=[0-9]+&/,'')
        }
        window.location.href = href.replace(/(&){0,1}(\?){0,1}minprice=[0-9]+/i, "").replace(/(&){0,1}(\?){0,1}maxprice=[0-9]+/i, "");
    }
</script>
