<style>
    .become-customer-box{
        box-shadow : none !important;
        padding-left: 0px !important;
        padding-right: 0px !important;
        padding-top: 10px !important;
    }
    .newcustomer-area{
        padding: 0px !important;
        background: #FFF !important;
    }
    .segment-line{
        border: 0.1px solid #DADADA !important;
    }
    .price-match-helper-text-bold{
        font-weight: 600 !important;

        font-size: 16px !important;
    }
    .form-group input{
        max-width: unset !important;
    }
    .newcustomer-area .accountform-area .form-group{
        margin-bottom: 25px !important;
    }
    .cancel-link, .cancel-link:hover {
        cursor: pointer;
        color:#F85604;
    }
</style>

<section class="container-fluid newcustomer-area">
     <div class="container-fluid" style="background: #F1F3F6; padding: 10px;">
         <div class="container breadcrumb-bar" style="font-size: 13.71px;">

             <span class="muted"><a style="color: #A9A9A9;" href="@Url.RouteUrl("Homepage")">Inovatiqa</a> / </span> Contract Pricing
         </div>
         </div>
    <div class="row">
        <div class="container">
            <div class="row mt10">
                <div class="col-md-12">
                    <div class="become-customer-box">
                        <div class="row">
                            <div class="col-md-12">
                                <div class="font_lato">
                                    <div class="customer-select">
                                        <h4 class="heading-price-match">Contract Pricing</h4>
                                        <hr class="segment-line">
                                        <h5 class="sub-heading-price-match">Do you have a list of contracted items?</h5>
                                        <p class="price-match-helper-text">Complete & sumbit the form to have a sales specialists contact you within 24 - 48 hours.</p>
                                    </div>
                                </div>
                                
                                <div class="col-md-6">
                                    <div class="accountform-area font_lato" style="display: block;">
                                        @if (TempData["message"] != null && TempData["message"].ToString() != "")
                                        {
                                            <div class="alert alert-success" role="alert">
                                                @TempData["message"]
                                            </div>
                                        }
                                        <form class="createaccount-form" action="/FooterSendEmails" method="post">
                                            <input type="text" hidden name="EmailSubject" value="Contact Pricing" asp-for="EmailSubject" />
                                            <input type="text" hidden name="Method" value="@Url.RouteUrl("ContractPricing")" asp-for="Method" />
                                            <div class="row mt53 align_center">
                                                <div class="col-md-4 col-sm-12 col-xs-12 pl0">
                                                    <div class="form-group ">
                                                        <label class="required">Company / Facility Name</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-6 col-sm-12 col-xs-12">
                                                    <div class="form-group flex-col">
                                                        <input type="text" class="form-control" name="Company" data-val="true" autocomplete="off" data-val-required="Company / Facility is required." asp-for="Company"  />
                                                        <span asp-validation-for="Company" class="error-label mt10"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 col-sm-12 col-xs-12 pl0">
                                                    <div class="form-group">
                                                        <label class="required">Contact Name</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-6 col-sm-12 col-xs-12">
                                                    <div class="form-group flex-col">
                                                        <input type="text" class="form-control" name="CustomerFirstName" data-val="true" autocomplete="off" data-val-required="Contact Name is required." asp-for="CustomerFirstName" />
                                                        @*<label class="label-small">First & Last Name</label>*@
                                                        <span asp-validation-for="CustomerFirstName" class="error-label mt10"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 col-sm-12 col-xs-12 pl0">
                                                    <div class="form-group">
                                                        <label class="required">Email Address</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-6 col-sm-12 col-xs-12">
                                                    <div class="form-group flex-col">
                                                        <input type="email" class="form-control" name="CustomerEmail" data-val="true" autocomplete="off" data-val-required="Email is required." asp-for="CustomerEmail" />
                                                        <span asp-validation-for="CustomerEmail" class="error-label mt10"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 col-sm-12 col-xs-12 pl0">
                                                    <div class="form-group">
                                                        <label class="required">Phone Number</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-6 col-sm-12 col-xs-12">
                                                    <div class="form-group flex-col">
                                                        <input type="tel" class="form-control" maxlength="15"  id="phoneNumber" name="PhoneNumber" data-val="true" autocomplete="off" data-val-required="Phone Number is required." asp-for="PhoneNumber" />
                                                        <span asp-validation-for="PhoneNumber" class="error-label mt10"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-4 col-sm-12 col-xs-12 pl0 mt7">
                                                    <div class="form-group" style="margin-bottom: 5px !important;">
                                                        <label class="required">Comments</label>
                                                    </div>
                                                </div>
                                                <div class="col-md-10 col-sm-12 col-xs-12 pl0">
                                                    <div class="form-group flex-col">
                                                        <textarea rows="12" class="form-control custom-textarea mb0" style="max-width: unset;" name="Message" data-val="true" autocomplete="off" data-val-required="Comments are required." asp-for="Message"></textarea>
                                                        <span asp-validation-for="Message" class="error-label mt10"></span>
                                                    </div>
                                                </div>
                                                <div class="col-md-10 col-sm-12 col-xs-12 mt55">
                                                    <div class="pwd-btn text-right">
                                                        <a href="@Url.RouteUrl("Homepage")" class="cancel-link">Cancel</a>
                                                        <input type="submit" value="Submit Form" class="btn btn-signin">
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                                <div class="col-md-6 mt53">
                                    <img src="~/images/UIComponents/contract-pricing.png" style="height: 560px;" />
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="container-fluid" style="background: #F1F3F6; padding: 20px;"></div> 
</section>
<script>

    function clearForm() {
        $('form').trigger("reset");
    }

