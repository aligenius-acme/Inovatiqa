        font-weight: 500 !important;
    }

    .segment-line {
        border: 0.1px solid #DADADA !important;
        margin-top: 20px !important;
        margin-bottom: 25px !important;
    }

    .price-match-helper-text-bold {
        font-weight: 600 !important;
        font-size: 16px !important;
    }

