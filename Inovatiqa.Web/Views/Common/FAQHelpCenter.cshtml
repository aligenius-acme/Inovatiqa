<script>
    $('a').click(function () {
        setTimeout(function () {
            const list = ['.contact', '.payment', '.unlisted', '.return', '.salestax', '.internationalshipping', '.poshipping', '.siteerror', '.feedback'];
            const div = document.URL.split('#')[1];
            const showDiv = '.' + div;

            const index = list.indexOf(showDiv);
            if (index > -1) {
                list.splice(index, 1);
            }

            list.forEach(function (div) {
                $(div).hide();
            });

            $(showDiv).show();
        }, 100);
    });
</script>