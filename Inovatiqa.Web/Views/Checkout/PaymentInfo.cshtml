@using Inovatiqa.Core;
@using Inovatiqa.Web.Models.Payment;
@model PaymentInfoModel

@{
    Layout = null;
}
<script>
    async function initializeCard(payments){
        const card = await payments.card({
            "postalCode" : "@Model.BillingPostalCode",
        });
        await card.attach('#card-container');
        return card;
    }

    async function tokenize(paymentMethod) {
        const tokenResult = await paymentMethod.tokenize();
        if (tokenResult.status === 'OK') {
            return tokenResult.token;
        }
        else {
            let errorMessage = `Tokenization failed-status: ${tokenResult.status}`;
            if (tokenResult.errors) {
                errorMessage += ` and errors: ${JSON.stringify(
                    tokenResult.errors
                )}`;
            }
            throw new Error(errorMessage);
        }
    }
    
    async function verifyBuyer(nonce, payments) {
        const SaveCard = $('#SaveCard').is(':checked');
        CardIntent = SaveCard ? 'STORE' : 'CHARGE';
        const verificationDetails = {
            intent: CardIntent,
            amount: '@Model.OrderTotal',
            currencyCode: '@Model.Currency',
            billingContact: {
                givenName: '@Model.BillingFirstName',
                familyName: '@Model.BillingLastName',
                email: '@Model.BillingEmail',
                country: '@Model.BillingCountry',
                region: '@Model.BillingState',
                city: '@Model.BillingCity',
                postalCode: '@Model.BillingPostalCode'
            }
        };
        const verificationResult = await payments.verifyBuyer(nonce, verificationDetails);
        return verificationResult.token;
    }
    
    function displayPaymentResults(status) {
        const statusContainer = document.getElementById(
            'payment-status-container'
        );
        if (status === 'SUCCESS') {
            statusContainer.classList.remove('is-failure');
            statusContainer.classList.add('is-success');
        }
        else{
            statusContainer.classList.remove('is-success');
            statusContainer.classList.add('is-failure');
        }
        statusContainer.style.visibility = 'visible';
    }
    
    async function domContentLoading() {
        displayAjaxLoading(true);
        $('#@Html.IdFor(model => model.StoredCardId)').on('change', toggleStoredCard);
        toggleStoredCard();
        if (!window.Square) {
            throw new Error('Square.js failed to load properly');
        }
        
        const payments = window.Square.payments('@InovatiqaDefaults.ApplicationId', '@InovatiqaDefaults.LocationId');
        let card;
        try {
            card = await initializeCard(payments);
            displayAjaxLoading(false);
        }
        catch (e) {
            console.error('Initializing Card failed', e);
            displayAjaxLoading(false);
            return;
        } 
        
        async function handlePaymentMethodSubmission(event, paymentMethod) {
            const use3DSecure = @InovatiqaDefaults.Use3ds.ToString().ToLower()
            event.preventDefault();
            try {
                cardButton.disabled = true;
                // get Card Nonce
                const selectedCardId = $('#@Html.IdFor(model => model.StoredCardId)').val();
                let token;
                if(!selectedCardId || selectedCardId == "@Guid.Empty.ToString()")
                    token = await tokenize(paymentMethod);
                else
                    token = selectedCardId
                $('#@Html.IdFor(model => model.CardNonce)').val(token);
                // verify Buyer and add token
                if (use3DSecure) {
                    const verificationResult = await verifyBuyer(token, payments);
                    $('#@Html.IdFor(model => model.Token)').val(verificationResult);
                }

                // save payment
                PaymentInfo.save();
                displayPaymentResults('SUCCESS');
                console.debug('Payment Success', paymentResults);
            }
            catch (e) {
                cardButton.disabled = false;
                displayPaymentResults('FAILURE');
                console.error(e.message);
            }
        }
        
        const cardButton = document.getElementById('card-button');
        cardButton.addEventListener('click', async function(event) {
            $('#card-button').removeAttr('onclick');
            await handlePaymentMethodSubmission(event, card);
        });
        
    }

    function toggleStoredCard() {
            var selectedStoredCardId = $('#@Html.IdFor(model => model.StoredCardId)').val();
            if (!selectedStoredCardId || selectedStoredCardId == '@(Guid.Empty.ToString())') {
                $('#square-card-details').show();
            } else {
                $('#square-card-details').hide();
            }
        }
    
    
    if (document.readyState !== 'loading') {
        console.log('readystate');
        domContentLoading();  
    }
    else {

        document.addEventListener('DOMContentLoaded', domContentLoading);
    }
</script>


<input asp-for="CardNonce" type="hidden" />
<input asp-for="Token" type="hidden" />
<div class="payment_head">
    <label>Credit card</label>
    <div class="accept_logos">
        <img src="~/images/UIComponents/p5.png">
        <img src="~/images/UIComponents/p4.png">
        <img src="~/images/UIComponents/p1.png">
        <img src="~/images/UIComponents/p3.png">
        <img src="~/images/UIComponents/p2.png">
    </div>
</div>
<div class="payment_body">
    <div class="row">
        @if(!Model.IsGuest && Model.StoredCards.Any())
        {
            <div class="col-md-12 col-sm-12 col-xs-12 from-group" style="margin-bottom:40px;">
                <select class="form-control square-input" asp-for="StoredCardId" asp-items="Model.StoredCards" onchange="handleChange(this)"></select>
            </div>
        }
        <div id="square-card-details">
            <div id="card-container" style="padding-right:15px; padding-left:15px;"></div>
            @if (!Model.IsGuest)
            {
                <div class="col-md-6 col-sm-6 col-xs-6 form-group">
                    <label>Save Option</label>
                    <div class="checkbox" style="margin-top:0px;">
                        <label>
                            <input asp-for="SaveCard" type="checkbox" name="SaveCard" id="SaveCard" style="height: 20px; width:20px;" />
                            Save card for future purchases.
                        </label>
                        <span asp-validation-for="SaveCard"></span>
                    </div>
                </div>
            }
            <div id="payment-status-container"></div>
        </div>
    </div>
</div>
<script>
    function handleChange(e) {
        const value = $(e).find(':selected').val();
        if (value != '00000000-0000-0000-0000-000000000000') {

        }
    }
</script>