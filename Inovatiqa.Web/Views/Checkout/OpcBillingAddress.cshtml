@model CheckoutBillingAddressModel
@*
<div class="checkout-data">
    @if (Model.ShipToSameAddressAllowed)
    {
        <div class="section ship-to-same-address">
            <p class="selector">
                <input type="checkbox" checked="" data-val="true" data-val-required="The ShipToSameAddress field is required." id="ShipToSameAddress" name="ShipToSameAddress" value="true">
                <label for="ShipToSameAddress">Ship to the same address</label>
            </p>
        </div>
    }
    @if (Model.ExistingAddresses.Count > 0)
    {
        <div class="section select-billing-address">
            <label for="billing-address-select">Select a billing address from your address book or enter a new address.</label>
            @if (Model.InvalidExistingAddresses.Count > 0)
                {
                    <label class="min-amount-warning">
                        @string.Format("You have {0} invalid address(es)", Model.InvalidExistingAddresses.Count)
                    </label>
                }
        <div style="width:100%">
            <div style="margin-left:25%; margin-right:auto">
                <select name="billing_address_id" id="billing-address-select" class="address-select form-control dropdown-toggle"
                        title="" style="width:550px" onchange="Billing.newAddress(!this.value)">
                    @foreach (var address in Model.ExistingAddresses)
                    {
                        var addressLine = "";
                        addressLine += address.FirstName;
                        addressLine += " " + address.LastName;
                        if (address.StreetAddressEnabled && !string.IsNullOrEmpty(address.Address1))
                        {
                            addressLine += ", " + address.Address1;
                        }
                        if (address.CityEnabled && !string.IsNullOrEmpty(address.City))
                        {
                            addressLine += ", " + address.City;
                        }
                        if (address.CountyEnabled && !string.IsNullOrEmpty(address.County))
                        {
                            addressLine += ", " + address.County;
                        }
                        if (address.StateProvinceEnabled && !string.IsNullOrEmpty(address.StateProvinceName))
                        {
                            addressLine += ", " + address.StateProvinceName;
                        }
                        if (address.ZipPostalCodeEnabled && !string.IsNullOrEmpty(address.ZipPostalCode))
                        {
                            addressLine += " " + address.ZipPostalCode;
                        }
                        if (address.CountryEnabled && !string.IsNullOrWhiteSpace(address.CountryName))
                        {
                            addressLine += ", " + address.CountryName;
                        }
                        //how should we render "FormattedCustomAddressAttributes" here?
                        <option value="@(address.Id)">@(addressLine)</option>
                    }
                    <option value="" selected="@Model.NewAddressPreselected">New Address</option>
                </select>
            </div>
        </div>
        </div>
    }
    <div class="section new-billing-address" id="billing-new-address-form">
        <div class="enter-address">
            <div style="margin-left:18%;margin-right:15%">
                <div asp-validation-summary="ModelOnly" class="message-error"></div>
                @{
                    var dataDictAddress = new ViewDataDictionary(ViewData);
                    dataDictAddress.TemplateInfo.HtmlFieldPrefix = "BillingNewAddress";
                    @await Html.PartialAsync("_CreateOrUpdateAddress", Model.BillingNewAddress, dataDictAddress)
                }
            </div></div>
    </div>
</div>
    *@
<div class="row flex_col align_center">
    <div class="col-md-8">
        <h2>Billing Info</h2>
        <p>Please enter your Billing Information</p>
    </div>
    <div class="col-md-4 text-right">
        <p>Step 1 of 5</p>
    </div>
</div>
<div class="row flex_col m_t_30">
    <div class="col-md-12 col-sm-12 col-xs-12 form-group">
        @if (Model.ExistingAddresses.Count > 0)
        {
            @if (Model.InvalidExistingAddresses.Count > 0)
            {
                <div class="alert alert-danger" role="alert">
                    @string.Format("You have {0} invalid {1}", Model.InvalidExistingAddresses.Count, Model.InvalidExistingAddresses.Count > 1 ? "addresses" : "address")
                </div>
            }
            <label>Please Select Billing Address</label>
            <select class="form-control" name="billing_address_id" id="billing-address-select" onchange="BillingChange(this.value)">
                <option>Please select an address</option>
                @foreach (var address in Model.ExistingAddresses)
                {
                    var addressLine = "";
                    addressLine += address.FirstName;
                    addressLine += " " + address.LastName;
                    if (address.StreetAddressEnabled && !string.IsNullOrEmpty(address.Address1))
                    {
                        addressLine += ", " + address.Address1;
                    }
                    if (address.CityEnabled && !string.IsNullOrEmpty(address.City))
                    {
                        addressLine += ", " + address.City;
                    }
                    if (address.CountyEnabled && !string.IsNullOrEmpty(address.County))
                    {
                        addressLine += ", " + address.County;
                    }
                    if (address.StateProvinceEnabled && !string.IsNullOrEmpty(address.StateProvinceName))
                    {
                        addressLine += ", " + address.StateProvinceName;
                    }
                    if (address.ZipPostalCodeEnabled && !string.IsNullOrEmpty(address.ZipPostalCode))
                    {
                        addressLine += " " + address.ZipPostalCode;
                    }
                    if (address.CountryEnabled && !string.IsNullOrWhiteSpace(address.CountryName))
                    {
                        addressLine += ", " + address.CountryName;
                    }
                    <option value="@(address.Id)">@(addressLine)</option>
                }
                <option value="" selected="@Model.NewAddressPreselected">New Address</option>
            </select>
        }
    </div>
    <div id="billing-new-address-form">
        <div asp-validation-summary="ModelOnly" class="message-error"></div>
        @{
            var dataDictAddress = new ViewDataDictionary(ViewData);
            dataDictAddress.TemplateInfo.HtmlFieldPrefix = "BillingNewAddress";
            @await Html.PartialAsync("_CreateAddressCheckout", Model.BillingNewAddress, dataDictAddress)
            //@await Html.PartialAsync("_CreateOrUpdateAddress", Model.BillingNewAddress, dataDictAddress)
        }
        <div class="col-md-12">
            <div class="signin-btn font_roboto">
                <input type="button" value="Create Address" class="btn btn-signin" onclick="Billing.save()">
            </div>
        </div>
    </div>
    @if (Model.ShipToSameAddressAllowed)
    {
        <div class="col-md-6 col-sm-12 col-xs-12 form-group">
            <div class="checkbox">
                <label><input type="checkbox" checked="" data-val="true" data-val-required="The ShipToSameAddress field is required." id="ShipToSameAddress" name="ShipToSameAddress" value="true"> Ship to the same address</label>
            </div>
        </div>
    }
</div>

<script>
    function BillingChange(val) {
        if (val > 0) {
            Billing.save()
        }
        else {
            Billing.newAddress(!val);
        }
    }
</script>