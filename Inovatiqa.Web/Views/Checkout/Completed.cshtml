<button id="btn" data-toggle="modal" data-target="#final_modal" style="position: fixed;"></button>

<script>
	$(document).ready(function () {
		$('#btn').click();
        $("#final_modal").on("hidden.bs.modal", function () {
            window.location.href = "@Url.RouteUrl("Homepage")"
        });
    });
</script>