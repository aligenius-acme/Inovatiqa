@model CheckoutCompletedModel
@{
    Layout = "_ColumnsOne";
}
@{
    ViewBag.Title = "Order Placed";
}
@if (!Model.OnePageCheckoutEnabled)
{
    @await Component.InvokeAsync("CheckoutProgress", new { step = CheckoutProgressStep.Complete })
}
