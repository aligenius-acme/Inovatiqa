@Html.Resource(@<script type="text/javascript">
                                                    function handleButtonValueUpdate() {
                                                        $('#itemsCount').html($("input[name='chkaddTocart']:checked").length)
                                                        return true;
                                                    }
                                                function categoryFilter() {
                                                    var category = $('#filterCategaries').val();
                                                    setLocation('@Url.RouteUrl("ReorderGuide")?filterCategories=' + category);
                                                }
            $('#reorderClear').click(function() {
                setLocation('@Url.RouteUrl("ReorderGuide")');
            });
                                                    $(document).ready(function () {
                                                        const table = $('#reorder-guide').DataTable({
                                                            "language": {
                                                                "info": '<div class="tpage-num"><p>Showing _START_ to _END_ of _TOTAL_ Items</p></div>'
                                                            },
                                                            "pageLength": 5,
                                                            "dom": 't<"jqueryPagination"ip>',
                                                            'pagingType': 'numbers',
                                                            'ordering': false
                                                        });
                                                        $('#search').keyup(function () {
                                                            table
                                                                .search(this.value)
                                                                .draw();
                                                        });
                                                    });
        ;</script>, "js")