                                                            <table class="table border-collapse mb0" id="reorder-guide">
                                                                <thead>
                                                                    <tr>
                                                                        <th></th>
                                                                        <th>Item Number</th>
                                                                        <th>Description</th>
                                                                        <th>Last Order Date</th>
                                                                        <th>UOM</th>
                                                                        <th>Price</th>
                                                                        <th>Average Quantity</th>
                                                                        <th>Add</th>
                                                                    </tr>
                                                                </thead>
                                                                <tbody>

                                                                    @if (Model.ReorderProducts.Count > 0)
                                                                    {
                                                                        @foreach (var reorderItem in Model.ReorderProducts)
                                                                        {
                                                                            <tr>
                                                                                <td>
                                                                                    <div class="custom-control custom-checkbox">
                                                                                        <input type="checkbox" name="chkaddTocart" orderId="@reorderItem.OrderId" orderItemId="@reorderItem.Id" onclick="handleButtonValueUpdate() && AjaxCart.chkboxreorderitem()" class="custom-control-input">
                                                                                    </div>
                                                                                </td>
                                                                                <td>
                                                                                    @if (reorderItem.MSku != null)
                                                                                    {
                                                                                        <p style="color: #636363;">@reorderItem.MSku</p>
