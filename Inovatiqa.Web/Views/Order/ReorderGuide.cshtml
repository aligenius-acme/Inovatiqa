                                                                                <select name="@(controlId)" id="@(controlId)" class="btn-dropdown form-control uom" @(attribute.Values.Any(value => value.CustomerEntersQty) ? Html.Raw(string.Format("onchange=\"showHideDropdownQuantity('{0}')\"", controlId)) : null)>
                                                                                    @foreach (var attributeValue in attribute.Values)
                                                                                    {
