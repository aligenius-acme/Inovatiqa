                                                                                    {
                                                                                        @foreach (var attribute in reorderItem.ProductAttributesAndValues)
                                                                                        {
                                                                                            var controlId = $"{InovatiqaDefaults.ProductAttributePrefix}{attribute.Id}";
                                                                                            <div id="@($"{InovatiqaDefaults.ProductAttributePrefix}input_{attribute.Id}")" class="form-group">
                                                                                                @switch (attribute.AttributeControlTypeId)
                                                                                                {
                                                                                                    case (int)AttributeControlType.DropdownList:
                                                                                                        {
                                                                                                            if (attribute.Name == "UOM")
                                                                                                            {
                                                                                                                <select name="@(controlId)" id="@(controlId)" class="form-control uom" style="margin-top: 15px;" @(attribute.Values.Any(value => value.CustomerEntersQty) ? Html.Raw(string.Format("onchange=\"showHideDropdownQuantity('{0}')\"", controlId)) : null)>
                                                                                                                    @foreach (var attributeValue in attribute.Values)
                                                                                                                    {
                                                                                                                        <option selected="@attributeValue.IsPreSelected" value="@attributeValue.Id" msku="@attributeValue.MSku">@attributeValue.Name</option>
                                                                                                                    }
                                                                                                                </select>
                                                                                                            }
                                                                                                        }
                                                                                                        break;
                                                                                                }
                                                                                            </div>
                                                                                        }
                                                                                    }
                                                                                </td>
                                                                                <td>
                                                                                    <p style="color: #636363;">@reorderItem.OrderItemPrice</p>
                                                                                </td>
                                                                                <td style="width: 1vw;">
                                                                                    <div class="form-group">
                                                                                        <input type="text" class="form-control qty" style="margin-left: unset; margin-top: 15px;" value="@reorderItem.Qty">
                                                                                    </div>
                                                                                </td>
                                                                                <td>
                                                                                    <img src="~/images/UIComponents/addicon-td.svg" alt="" onclick="AjaxCart.addproducttocart_reorder('@Url.RouteUrl("AddProductToCart-Reorder", new { orderId = reorderItem.OrderId, orderLineId = reorderItem.Id, qty=reorderItem.Qty })');return false;" style="cursor: pointer;">
                                                                                </td>
                                                                            </tr>
                                                                        }
                                                                    }
                                                                    else
                                                                    {
                                                                        <tr>
                                                                            <td colspan="10">
                                                                                <div class="no-data">
                                                                                    No orders found in past. Please create some orders first.
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    }

                                                                </tbody>
                                                            </table>
                                                 
</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
