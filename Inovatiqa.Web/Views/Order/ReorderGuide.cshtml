                                                                                        <p style="color: #636363;">-</p>
                                                                                    }
                                                                                </td>
                                                                                <td style="width: 15vw;">
                                                                                    <a style="color: #0068A3;" href="@Url.RouteUrl("Product", new { SeName = reorderItem.ProductSeName })">@reorderItem.Name</a>
                                                                                    <p>Manufacturer / Manufacturer #</p>
                                                                                    @{
                                                                                        string manufacturers = string.Empty;
                                                                                                                                        @foreach (var manufacturer in reorderItem.ProductManufacturers)
                                                                                        {
                                                                                            manufacturers += manufacturer.Name + " ";
                                                                                        }
                                                                                                                                        <p>@manufacturers / @(!String.IsNullOrEmpty(reorderItem.ManufacturerPartNumber) ? reorderItem.ManufacturerPartNumber.Replace("Mfr#", "") : "") </p>
                                                                                    }
                                                                                </td>
