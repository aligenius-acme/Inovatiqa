@Html.Resource(@<script type="text/javascript">
                    var items = 0;
                    function addtocartCount(selector) {
                        var id = $(selector).attr('data');
                        if (items == 0) {
                            $('#addToCartList').attr('disabled');
                        }
                        if (selector.checked) {
                            $('#addToCartList').removeAttr('disabled');
                            $('#addToCartList').val(`Add ITEM TO CART (${++items})`);
                            $('[data=' + id + ']').attr('checked', true);
                            $('#addToCartList').removeClass('btn_disable');
                        }
                        else {
                            $('#addToCartList').removeAttr('disabled');
                            $('#addToCartList').val(`Add ITEM TO CART (${--items})`);
                            $('[data=' + id + ']').attr('checked', false);
                        }
                    }
                    function hideAddToCart(elem) {
                        $('.btn.btn-items').removeClass('active');
                        elem.classList.add('active')
                        $('#addToCartList').hide();
    }
    function showAddToCart(elem) {
        $('.btn.btn-items').removeClass('active');
        elem.classList.add('active')
        $('#addToCartList').show();
    }
</script>, "js")
