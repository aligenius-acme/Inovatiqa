@foreach (var shipment in Model.ShipmentDetails)
{
    var si = shipment.Items.ToList();
   <div class="modal fade" id="myModal-@(shipment.Id)">
        <div class="modal-dialog" style="width:60vw;" role="document">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #0068A3;">
                    <h4 class="modal-title" style="color:white;">Invoice Summary</h4>
                    <h5 class="modal-title" style="color:white;">Invoice# @shipment.Id</h5>
                </div>
                <div class="modal-body" style="border-bottom:0px solid white;">

                    <table class="table-condensed">
                        <thead>
                            <tr>
                                <th>Item Number</th>
                                <th>Description</th>
                                <th>QTY Oredered</th>
                                <th>QTY Shipped</th>
                                <th>Unit Price</th>
                                <th>Shipped Price</th>
                            </tr>
                        </thead>
                        <tbody class="table">
                            @foreach (var item in si)
                            {
                                var unitPrice = shipment.Order.Items.ToList().Find(oi => oi.ProductId == item.ProductId).UnitPrice;
                                var shippedPrice = Convert.ToDecimal(unitPrice.Replace("$", "").Replace(" ", "").Replace(",", "")) * item.QuantityShipped;
                                <tr style="border-top:1px solid grey;">
                                    <td><a href="@Url.RouteUrl("Product", new { SeName = item.ProductSeName})"><p>@item.Sku</p></a></td>
                                    <td><a href="@Url.RouteUrl("Product", new { SeName = item.ProductSeName})" style="color:unset;"><p>@item.ProductName</p></a></td>
                                    <td><p>@item.QuantityOrdered</p></td>
                                    <td><p>@item.QuantityShipped</p></td>
                                    <td><p>@unitPrice</p></td>
                                    <td><p>$@shippedPrice</p></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-primary" style="color: white; background-color: #0068A3;" data-dismiss="modal">Close</button>
                </div>
            </div>
        </div>

    </div>
}
