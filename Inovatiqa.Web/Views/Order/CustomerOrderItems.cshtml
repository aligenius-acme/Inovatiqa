                                                        $("#customer-orders-filter").click(function () {
                                                            reloadwithParams();
                                                        });
                                                        $(".ordertabs").click(function () {
                                                            reloadwithParams();
                                                        });
                                                        function reloadwithParams() {
                                                            var startDateValue = $("#fromDate").val();
                                                            var endDateValue = $("#toDate").val();
                                                            var category = Number($("#filterCategaries").val());

                                                            if (startDateValue == '' || endDateValue == '') {
                                                                alert("Please select date range first!");
                                                                return;
                                                            }

                                                            if ($.datepicker.parseDate("mm/dd/yy", endDateValue) < $.datepicker.parseDate("mm/dd/yy", startDateValue)) {
                                                                alert("End date must be greater than start date!");
                                                                return;
                                                            }
                                                            if ($(event.currentTarget).attr('class').search("ordertabs") != -1) {
                                                                console.log('Hit 1');
                                                                shippedItems = $(event.currentTarget).attr('value');
                                                            }
                                                            else if (searchParams.has('shippedItems')){
                                                                shippedItems = searchParams.get('shippedItems');
                                                                console.log('Hit 2');
                                                            }
                                                            if (isReturnview) {
                                                                setLocation('@Url.RouteUrl("CustomerOrderItems")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue + '&filterCategoryId=' + category + '&shippedItems=' + shippedItems + '&returnView=true');
                                                            }
                                                            //else if ($('#filterCategaries').val() > 0) {
                                                              //  setLocation('UrlRouteUrl"CustomerOrderItems")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue + '&filterCategoryId=' + category  + '&shippedItems=' + shippedItems);
                                                            //}
                                                            else {
                                                                //orderStatusId = $('li.active a').attr("value");
                                                                setLocation('@Url.RouteUrl("CustomerOrderItems")?startDateValue=' + startDateValue + '&endDateValue=' + endDateValue + '&filterCategoryId=' + category  + '&shippedItems=' + shippedItems);
                                                            }
                                                        }

                                                        $("#customer-orders-clear").click(function () {
                                                            debugger;
                                                            if (isReturnview)
                                                                setLocation('@Url.RouteUrl("CustomerOrderItems")?returnView=true');
                                                            else {
                                                                setLocation('@Url.RouteUrl("CustomerOrderItems")');
                                                            }
                                                        });

                                                        if (searchParams.has('startDateValue') && searchParams.has('endDateValue')) {
                                                            $("#fromDate").val(searchParams.get('startDateValue'));
                                                            $("#toDate").val(searchParams.get('endDateValue'));
                                                            $('#pageTitle').append(" " + searchParams.get('startDateValue') + " to " + searchParams.get('endDateValue'));
                                                            $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("StartDate", searchParams.get('startDateValue')));
                                                            $('#emptyRow td').eq(0).text($('#emptyRow td').eq(0).text().replace("EndDate", searchParams.get('endDateValue')));
                                                        }
                                                        else {
                                                            var dateOffset = (24 * 60 * 60 * 1000) * 35; //5 days
                                                            var myDate = new Date();
                                                            myDate.setTime(myDate.getTime() - dateOffset);
                                                            $('#pageTitle').append(" " + formatDate(myDate) + " to " + formatDate(new Date()));
                                                        }

                                                        $(".order-track-button").click(function () {
                                                            var orderId = $(this).attr("orderId");
                                                            var url = "/orderdetails/" + orderId + "?trackView=true";
                                                            window.location.href = url;
                                                        });
                                                        function formatDate(date) {
                                                            var d = new Date(date),
                                                                month = '' + (d.getMonth() + 1),
                                                                day = '' + d.getDate(),
                                                                year = d.getFullYear();

                                                            if (month.length < 2)
                                                                month = '0' + month;
                                                            if (day.length < 2)
                                                                day = '0' + day;

                                                            return [month, day, year].join('/');
                                                        }
