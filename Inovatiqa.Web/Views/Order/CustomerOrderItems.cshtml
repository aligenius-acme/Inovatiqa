                                                        let searchParams = new URLSearchParams(window.location.search);
                                                        var shippedItems = 0;
                                                        if (searchParams.has('shippedItems')) {
                                                            $('.order-list li').removeClass("active");
                                                            $('.order-list li[value="' + searchParams.get('shippedItems') + '"]').addClass("active");
                                                        }
                                                        var isReturnview = @Model.IsReturnView.ToString().ToLower();

                                                        if(!isReturnview)
                                                            shippedItems = $('.ordertabs').val();

