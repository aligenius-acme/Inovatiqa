                        });
                        var items = 0;
                        function addtocartCount(selector) {
                            var id = $(selector).attr('data');
                            if (items == 0) {
                                $('#addToCartList').attr('disabled');
                            }
                            if (selector.checked) {
                                $('#addToCartList').removeAttr('disabled');
                                $('#addToCartList').val(`Add ITEM TO CART (${++items})`);
                                $('[data=' + id + ']').attr('checked', true);
                            }
                            else {
                                $('#addToCartList').removeAttr('disabled');
                                $('#addToCartList').val(`Add ITEM TO CART (${--items})`);
                                $('[data=' + id + ']').attr('checked', false);
                            }
                        }
                        function toggleAddToCart() {
                            $('#addToCartList').toggle();
                        }
    </script>, "js")
