<style>
    .jqueryPagination{
        display: @(Model.Items.Count > 0 ? "flex" : "none");
        justify-content: space-between;
        margin: 8px 12px;
    }
    .paging_numbers span a {
        margin-right: 5px;
        cursor: pointer;
        color: #636363;
    }
    .paging_numbers span .current{
        color: #000;
    }
    .jqueryPagination p {
        font-family: Lato;
        font-style: normal;
        font-weight: normal;
        font-size: 13.5px;
        letter-spacing: 0.05em;
        color: #636363;
        margin-bottom:unset;
    }
    td {
        vertical-align: middle;
    }
    .orderstatus-area .items-table-area .table tbody tr {
        border-bottom: 1px solid #E2E8F0 !important;
    }
</style>

@{
    string date = "";
    if (@Model.Shipments.Count > 0)
        date = @Model.Shipments.OrderByDescending(x => x.ShippedDate).Select(x => x.ShippedDate).FirstOrDefault()?.ToString("MM/dd/yyyy");
    var shippedItems = Model.Items.Where(x => x.IsShipped == true).ToList();
}

