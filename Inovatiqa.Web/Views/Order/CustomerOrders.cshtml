                                                                    <th>Date</th>
                                                                    <th>Ship to</th>
                                                                    <th>City</th>
                                                                    <th>State</th>
                                                                    <th>Ship to Number</th>
                                                                    <th>Order Total</th>
                                                                    <th>Order Number</th>
                                                                    <th>PO</th>
                                                                    <th>Total Items</th>
                                                                    <th>B/O</th>
                                                                    <th>Status</th>
                                                                    <th>View</th>
                                                                </tr>
                                                            </thead>

                                                            <tbody>
                                                                @if (Model.Orders.Count > 0)
                                                                {
                                                                    foreach (var order in Model.Orders)
                                                                    {
                                                                        <tr>
                                                                            <td><p>@order.CreatedOn.ToString("MM/dd/yyyy")</p></td>
                                                                            <td><p>@order.ShipTo</p></td>
                                                                            <td><p>@order.ShipToCity</p></td>
                                                                            <td><p>@order.ShipToState</p></td>
                                                                            <td><p class="num-green">@order.ShipToId</p></td>
                                                                            <td><p>@order.OrderTotal</p></td>
                                                                            <td><p>@order.Id</p></td>
                                                                            <td><p>@order.PONumber</p></td>
                                                                            <td><p>@order.TotalItems</p></td>
                                                                            <td><p>@order.Bo</p></td>
                                                                            <td><a href="#"><p style="color: #0068A3;">@order.OrderStatus</p></a></td>
                                                                            <td><a href="/orderdetails/@order.Id?trackView=true"><p class="track-blue">View</p></a></td>
                                                                        </tr>
                                                                    }
                                                                }

                                                            </tbody>
                                                        </table>
                                                    </div>

                                                </div>

                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>
