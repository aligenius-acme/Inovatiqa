    <div class="page account-page order-list-page from-panel">
        <div class="page-title panel-heading">
            <h1 id="pageTitle">Submitted Order Status</h1>
        </div>
        <div class="page-body">
            @@if (Model.RecurringOrders.Count > 0)
            {
                <form asp-route="CustomerOrders" method="post">
                    @{
                        var canRetryRecurringOrders = Model.RecurringOrders.Any(recurring => recurring.CanRetryLastPayment);
                    }
                    @Html.AntiForgeryToken()
                    <div class="section recurring-payments">
                        <div class="title">
                            <strong>Recurring payments</strong>
                        </div>
                        <div class="recurring-payments-box">
                            <div class="panel panel-default">
                                <table class="table table-bordered">
                                    <colgroup>
                                        <col />
                                        <col />
                                        <col />
                                        <col />
                                        <col />
                                        <col />
                                        @if (canRetryRecurringOrders)
                                        {
                                            <col />
                                        }
                                        <col />
                                    </colgroup>
                                    <thead>
                                        <tr>
                                            <th class="a-center start-date">
                                                Start date
                                            </th>
                                            <th class="a-center cycle-info">
                                                Cycle info
                                            </th>
                                            <th class="a-center next-payment">
                                                Next payment
                                            </th>
                                            <th class="a-center total-cycles">
                                                Total cycles
                                            </th>
                                            <th class="a-center cycles-remaining">
                                                Cycles remaining
                                            </th>
                                            <th class="a-center initial-order">
                                                Initial order
                                            </th>
                                            <th class="a-center cancel">
                                                Cancel payment
                                            </th>
                                            @if (canRetryRecurringOrders)
                                            {
                                                <th class="retry">
                                                    Retry last payment
                                                </th>
                                            }
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @foreach (var item in Model.RecurringOrders)
                                        {
                                            <tr>
                                                <td class="a-center start-date">
                                                    @item.StartDate
                                                </td>
                                                <td class="a-center cycle-info">
                                                    @item.CycleInfo
                                                </td>
                                                <td class="a-center next-payment">
                                                    @item.NextPayment
                                                </td>
                                                <td class="a-center total-cycles">
                                                    @item.TotalCycles
                                                </td>
                                                <td class="a-center cycles-remaining">
                                                    @item.CyclesRemaining
                                                </td>
                                                <td class="a-center initial-order">
                                                    <a href="@Url.RouteUrl("OrderDetails", new { orderId = item.InitialOrderId })">@string.Format("View order (Order number - {0})", item.InitialOrderId)</a>
                                                </td>
                                                @if (canRetryRecurringOrders)
                                                {
                                                    <td class="retry">
                                                        @if (item.CanRetryLastPayment)
                                                        {
                                                            <input type="submit" name="retryLastPayment_@(item.Id)" value="Retry last payment" class="btn btn-default retry-recurring-order-button" />
                                                        }
                                                    </td>
                                                }
                                                <td class="a-center cancel">
                                                    @if (item.CanCancel)
                                                    {
                                                        <input type="submit" name="cancelRecurringPayment@(item.Id)" value="Cancel payment" class="btn btn-default cancel-recurring-order-button" />
                                                    }
                                                </td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>
                </form>
                if (Model.RecurringPaymentErrors.Any())
                {
                    <div class="message-error">
                        <ul>
                            @foreach (var error in Model.RecurringPaymentErrors)
                            {
                                <li>@error</li>
                            }
                        </ul>
                    </div>
                }
            }@
